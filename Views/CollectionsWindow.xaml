<Window x:Class="ComicReader.Views.CollectionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ComicReader.Views.Controls"
    xmlns:cv="clr-namespace:ComicReader.Controls"
        xmlns:vm="clr-namespace:ComicReader.ViewModels"
        xmlns:conv="clr-namespace:ComicReader.Views.Converters"
    Title="Favoritos y Colecciones" Height="700" Width="1100" Background="{DynamicResource CS_Background}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ComicReader;component/Themes/CollectionsResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:TotalItemsConverter x:Key="TotalItemsConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Window.DataContext>
        <vm:CollectionsViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}" />
    </Window.InputBindings>

    <Grid Margin="20" PreviewKeyDown="Window_PreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Border Grid.ColumnSpan="2" Background="#6B5CE8" CornerRadius="8" Padding="20" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="★ FAVORITOS Y COLECCIONES" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                <TextBlock Text="Organiza y gestiona tus cómics favoritos en colecciones personalizadas" Foreground="#E8E8FF" HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <!-- Left: actions + list -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource CS_CardBackground}" CornerRadius="10" Padding="12" Margin="0,0,12,0">
            <StackPanel>
                <!-- Buttons column (styled) -->
                <StackPanel>
                    <StackPanel.Resources>
                        <Style x:Key="ModernButtonStyle" TargetType="Button">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="Margin" Value="6,6,6,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>

                    <TextBlock Text="COLECCIONES" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource CS_TextPrimary}" Margin="6" />
                    <Button Style="{StaticResource ModernButtonStyle}" Background="#10B981" Foreground="White" Command="{Binding NewCommand}">Nueva Colección</Button>
                    <Button x:Name="BtnRename" Style="{StaticResource ModernButtonStyle}" Background="#3B82F6" Foreground="White" Click="BtnRename_Click">Renombrar</Button>
                    <Button x:Name="BtnDuplicate" Style="{StaticResource ModernButtonStyle}" Background="#8B5CF6" Foreground="White" Click="BtnDuplicate_Click">Duplicar</Button>
                    <Button x:Name="BtnFavorites" Style="{StaticResource ModernButtonStyle}" Background="#F59E0B" Foreground="White" Click="OpenFavorites_Click">Ver Favoritos</Button>
                    <Button x:Name="BtnDelete" Style="{StaticResource ModernButtonStyle}" Background="#EF4444" Foreground="White" Click="BtnDelete_Click">Eliminar Colección</Button>
                </StackPanel>

                <!-- Collections list below buttons -->
                <Separator Margin="6,12" />
                <TextBox x:Name="SearchBox" Width="260" Margin="6,0,6,8" TextChanged="SearchBox_TextChanged" />
                <TextBlock Text="Resumen" FontWeight="Bold" Margin="6,6,6,0" />
                <StackPanel Orientation="Horizontal" Margin="6,4,6,8">
                    <TextBlock Text="Colecciones: " FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Collections.Count}" VerticalAlignment="Center" />
                    <TextBlock Text="  " />
                    <TextBlock Text="Ítems: " FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Collections, Converter={StaticResource TotalItemsConverter}}" VerticalAlignment="Center" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="True">
                    <ListBox x:Name="CollectionsListBox" ItemsSource="{Binding Collections}"
                             SelectedItem="{Binding SelectedCollection, Mode=TwoWay}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <controls:CollectionCard />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Right: main editor / preview -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource CS_CardBackground}" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock Text="Selecciona una colección" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource CS_TextPrimary}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <CheckBox x:Name="ShowFavoritesOnly" Content="Mostrar favoritos" VerticalAlignment="Center" Margin="0,0,12,0" Checked="ShowFavoritesOnly_Checked" Unchecked="ShowFavoritesOnly_Unchecked" />
                        <Button Content="Agregar" Margin="6" Background="#3B82F6" Foreground="White" Click="AddCollectionItem_Click" />
                        <Button Content="Quitar" Margin="6" Background="#EF4444" Foreground="White" Click="RemoveCollectionItem_Click" />
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1" Background="#F7FAFC" CornerRadius="8" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListView x:Name="ItemsListView" ItemsSource="{Binding SelectedItems}" SelectionMode="Extended" BorderThickness="0" Background="Transparent">
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="140" Height="200" Background="White" Margin="8" CornerRadius="8" Padding="6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!-- Use ProgressComicItem to lazy-load thumbnail from ThumbPath -->
                                                <controls:ProgressComicItem ThumbnailPath="{Binding ThumbPath}" Title="{Binding Title}" Grid.Row="0" />

                                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" Width="100" VerticalAlignment="Center" />
                                                    <ToggleButton IsChecked="{Binding IsFavorite, Mode=TwoWay}" Content="★" Width="28" Height="28" Margin="6,0,0,0" ToolTip="Marcar como favorito" Checked="Favorite_Checked" Unchecked="Favorite_Unchecked" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#F3F6FB" CornerRadius="8" Padding="12" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Background="#8B5CF6" Foreground="White" Margin="6" Click="ExportCollections_Click">Exportar</Button>
                <Button Background="#059669" Foreground="White" Margin="6" Click="ImportCollections_Click">Importar</Button>
                <Button Background="#6B7280" Foreground="White" Margin="6" Click="CloseWindow_Click">Cerrar</Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>

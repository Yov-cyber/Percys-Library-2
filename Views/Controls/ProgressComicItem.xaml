<UserControl x:Class="ComicReader.Views.Controls.ProgressComicItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="72" Width="Auto">
    <Border Background="Transparent" Padding="6" x:Name="Root" ToolTip="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" AutomationProperties.Name="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" AutomationProperties.HelpText="{Binding AccessibilityHelp, RelativeSource={RelativeSource AncestorType=UserControl}}" Focusable="True">
        <Border.RenderTransform>
            <TranslateTransform Y="6" />
        </Border.RenderTransform>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="52" Height="64" Background="#0F000000" CornerRadius="4" VerticalAlignment="Center">
                <Grid>
                    <Image x:Name="ThumbnailImage" Stretch="Uniform" Opacity="0"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           RenderOptions.EdgeMode="Aliased" />
                    <!-- simple picture icon as placeholder -->
                    <Viewbox x:Name="PlaceholderIcon" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.65">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#FFB0B8BF" Data="M2,4 L22,4 L22,20 L2,20 Z M4,6 L20,6 L20,18 L4,18 Z M6,10 L10,14 L14,10 L18,14" />
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource RS_TextOnDarkBrush}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding PagesText, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource RS_TextOnDarkBrush}" FontSize="12" Opacity="0.85" Margin="0,2,0,4"/>
                <Grid>
                    <ProgressBar x:Name="InnerProgress" Style="{StaticResource RS_ProgressBarStyle}" Value="{Binding Percentage, RelativeSource={RelativeSource AncestorType=UserControl}}" Maximum="100" Height="12"/>
                    <TextBlock x:Name="PctText" Text="{Binding Percentage, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0:F0}%}" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"/>
                </Grid>
            </StackPanel>
        </Grid>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
    </Border>
</UserControl>

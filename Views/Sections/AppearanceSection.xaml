<UserControl x:Class="ComicReader.Views.Sections.AppearanceSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ComicReader.Views.Controls"
             Height="Auto" Width="Auto">
  <Border Style="{StaticResource SettingsCard}">
    <StackPanel>
      <TextBlock Text="Apariencia" FontWeight="Bold" FontSize="16" />
      <StackPanel Margin="0,8,0,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="🎨" FontSize="18" Margin="0,0,8,0" />
          <TextBlock Text="Tema" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
          <ComboBox SelectedItem="{Binding AppSettings.Theme, Mode=TwoWay}" ItemsSource="{Binding Themes}" Width="220" />
          <Button Style="{StaticResource ButtonComic}" Content="Previsualizar" Command="{Binding PreviewCommand}" Margin="8,0,0,0" />
          <Button Style="{StaticResource ButtonComic}" Content="Aplicar" Command="{Binding ApplyCommand}" Margin="8,0,0,0" />
        </StackPanel>

        <Separator Margin="0,12,0,12" />

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="🎯" FontSize="16" Margin="0,0,8,0" />
          <TextBlock Text="Acento" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
          <controls:ColorPickerSimple ColorHex="{Binding AppSettings.AccentColor, Mode=TwoWay}" />
          <TextBlock Text="Hex" Margin="8,4,0,0" Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
          <TextBlock Text="🔤" FontSize="16" Margin="0,0,8,0" />
          <TextBlock Text="Fuente" FontWeight="SemiBold" />
        </StackPanel>
        <ComboBox SelectedItem="{Binding AppSettings.FontFamily, Mode=TwoWay}" Width="260" Margin="0,6,0,0">
          <ComboBoxItem>Bangers</ComboBoxItem>
          <ComboBoxItem>Comic Neue</ComboBoxItem>
          <ComboBoxItem>Segoe UI</ComboBoxItem>
          <ComboBoxItem>Arial</ComboBoxItem>
        </ComboBox>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
          <TextBlock Text="🖼️" FontSize="16" Margin="0,0,8,0" />
          <TextBlock Text="Efectos" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
          <TextBlock Text="Halftone" VerticalAlignment="Center" Margin="0,0,8,0" />
          <controls:SliderComic Width="200" Value="{Binding AppSettings.HalftoneIntensity, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
          <TextBlock Text="Espaciado paneles" VerticalAlignment="Center" Margin="0,0,8,0" />
          <Slider Minimum="0" Maximum="32" Value="{Binding AppSettings.PanelSpacing, Mode=TwoWay}" Width="180" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
          <TextBlock Text="🔲" FontSize="14" Margin="0,0,8,0" />
          <TextBlock Text="Mostrar contornos de panel" VerticalAlignment="Center" />
          <controls:ToggleComic IsChecked="{Binding AppSettings.ShowPanelOutlines, Mode=TwoWay}" Margin="12,0,0,0" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
          <TextBlock Text="🖌️" FontSize="14" Margin="0,0,8,0" />
          <TextBlock Text="Efecto tinta" VerticalAlignment="Center" />
          <ComboBox SelectedItem="{Binding AppSettings.InkEffect, Mode=TwoWay}" Width="140" Margin="12,0,0,0">
            <ComboBoxItem>Outline</ComboBoxItem>
            <ComboBoxItem>Sketch</ComboBoxItem>
            <ComboBoxItem>None</ComboBoxItem>
          </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
          <TextBlock Text="🎚️" FontSize="14" Margin="0,0,8,0" />
          <TextBlock Text="Variante de contraste" VerticalAlignment="Center" />
          <ComboBox SelectedItem="{Binding AppSettings.ThemeAccentVariant, Mode=TwoWay}" Width="160" Margin="12,0,0,0">
            <ComboBoxItem>Default</ComboBoxItem>
            <ComboBoxItem>HighContrast</ComboBoxItem>
            <ComboBoxItem>Muted</ComboBoxItem>
          </ComboBox>
        </StackPanel>

      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>

<Window x:Class="ComicReader.Views.NewCollectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Colección" Height="300" Width="420" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

    <TextBlock Text="Nombre" FontWeight="Bold" />
    <TextBox x:Name="NameBox" Grid.Row="1" Margin="0,6,0,0" AutomationProperties.Name="Nombre de la nueva colección" />

        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <TextBlock Text="Descripción (opcional)" FontWeight="Bold" />
            <TextBox x:Name="DescBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,6,0,0" AutomationProperties.Name="Descripción de la nueva colección" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Seleccionar portada..." Click="SelectCover_Click" AutomationProperties.Name="Seleccionar portada" />
                <TextBlock x:Name="CoverPathText" Margin="8,6,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Width="220" AutomationProperties.Name="Ruta de la portada" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Width="84" Margin="6" Click="Cancel_Click" />
            <Button Content="Crear" Width="84" Margin="6" Click="Create_Click" />
        </StackPanel>
    </Grid>
</Window>

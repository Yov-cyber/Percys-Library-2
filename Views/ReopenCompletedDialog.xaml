<Window x:Class="ComicReader.Views.ReopenCompletedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reabrir cómic completado" Height="360" Width="540" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" BorderBrush="#2E3B4E" BorderThickness="1" CornerRadius="6" Background="#0F1B2B">
            <Image x:Name="CoverImage" Stretch="Uniform" Margin="6"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>

        <StackPanel Grid.Column="1" Margin="12,0,0,0">
            <TextBlock x:Name="TitleText" Text="Título del cómic" FontSize="16" FontWeight="Bold" Foreground="#212121" TextWrapping="Wrap" />
            <TextBlock x:Name="MetaText" Text="Completado el: --" FontSize="12" Foreground="#6B6B6B" Margin="0,4,0,8" />

            <TextBlock Text="Este cómic aparece como completado. ¿Cómo quieres abrirlo?" TextWrapping="Wrap" Margin="0,0,0,10" />

            <StackPanel>
                <RadioButton x:Name="RbStart" Content="Leer desde la primera página" IsChecked="True" Margin="0,4,0,4" />
                <RadioButton x:Name="RbContinue" Content="Continuar desde la última página leída" Margin="0,4,0,4" />
                <RadioButton x:Name="RbUnmark" Content="Marcar como no completado y abrir desde el principio" Margin="0,4,0,4" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="BtnCancel" Width="90" Margin="6,0,0,0">Cancelar</Button>
                <Button x:Name="BtnOk" Width="120" Margin="6,0,0,0" Background="#2E86AB" Foreground="White">Abrir cómic</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

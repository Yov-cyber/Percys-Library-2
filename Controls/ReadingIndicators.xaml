<UserControl x:Class="ComicReader.Controls.ReadingIndicators"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="400">
    
    <UserControl.Resources>
        <!-- Animaciones reutilizables -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeOutAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="1" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ScaleUpAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                           From="0.8" To="1.0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                           From="0.8" To="1.0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Estilos -->
        <Style x:Key="IndicatorBorder" TargetType="Border">
            <Setter Property="Background" Value="#E0000000"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.5" 
                                    BlurRadius="15" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IndicatorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Page Indicator (Centro superior) -->
        <Border x:Name="PageIndicator"
                Style="{StaticResource IndicatorBorder}"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,20,0,0"
                Opacity="0">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" CenterX="50" CenterY="20"/>
            </Border.RenderTransform>
            
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="PageText" 
                          Style="{StaticResource IndicatorText}"
                          Text="Página 1 de 24"
                          Margin="0,0,8,0"/>
                
                <!-- Barra de progreso -->
                <Border Width="100" Height="4" 
                       Background="#40FFFFFF" 
                       CornerRadius="2"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center">
                    <Border x:Name="ProgressBar"
                           Background="#FF4CAF50"
                           CornerRadius="2"
                           HorizontalAlignment="Left"
                           Width="20"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Zoom Indicator (Esquina superior izquierda) -->
        <Border x:Name="ZoomIndicator"
                Style="{StaticResource IndicatorBorder}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="20"
                Opacity="0">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            
            <StackPanel Orientation="Horizontal">
                <!-- Icono de zoom -->
                <Viewbox Width="20" Height="20" Margin="0,0,8,0">
                    <Canvas Width="24" Height="24">
                        <Path Fill="White" Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </Canvas>
                </Viewbox>
                
                <TextBlock x:Name="ZoomText" 
                          Style="{StaticResource IndicatorText}"
                          Text="100%"/>
            </StackPanel>
        </Border>

        <!-- Loading Indicator (Centro) -->
        <Border x:Name="LoadingIndicator"
                Style="{StaticResource IndicatorBorder}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0">
            <StackPanel Orientation="Horizontal">
                <!-- Spinner animado -->
                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                    <Canvas Width="50" Height="50">
                        <Path x:Name="SpinnerPath" 
                              Fill="Transparent" 
                              Stroke="White" 
                              StrokeThickness="4"
                              Data="M25,5 A20,20 0 0,1 45,25">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotation" 
                                               CenterX="25" CenterY="25"/>
                            </Path.RenderTransform>
                        </Path>
                    </Canvas>
                </Viewbox>
                
                <TextBlock x:Name="LoadingText" 
                          Style="{StaticResource IndicatorText}"
                          Text="Cargando..."/>
            </StackPanel>
        </Border>

        <!-- Bookmark Added Indicator (Centro) -->
        <Border x:Name="BookmarkIndicator"
                Style="{StaticResource IndicatorBorder}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            
            <StackPanel Orientation="Horizontal">
                <!-- Icono de marcador -->
                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                    <Canvas Width="24" Height="24">
                        <Path Fill="#FFD700" Data="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z"/>
                    </Canvas>
                </Viewbox>
                
                <TextBlock x:Name="BookmarkText" 
                          Style="{StaticResource IndicatorText}"
                          Text="Marcador agregado"/>
            </StackPanel>
        </Border>

        <!-- Panel Navigation Indicator (Lado derecho) -->
        <Border x:Name="PanelIndicator"
                Style="{StaticResource IndicatorBorder}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="20"
                Opacity="0">
            <StackPanel Orientation="Vertical">
                <TextBlock Style="{StaticResource IndicatorText}"
                          FontSize="14"
                          Text="Panel"
                          Margin="0,0,0,8"/>
                
                <TextBlock x:Name="PanelText" 
                          Style="{StaticResource IndicatorText}"
                          FontSize="20"
                          FontWeight="Bold"
                          Text="1/6"
                          Margin="0,0,0,8"/>
                
                <!-- Indicadores de paneles -->
                <StackPanel x:Name="PanelDots" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error Indicator (Centro) -->
        <Border x:Name="ErrorIndicator"
                Style="{StaticResource IndicatorBorder}"
                Background="#E0D32F2F"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0">
            <StackPanel Orientation="Horizontal">
                <!-- Icono de error -->
                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                    <Canvas Width="24" Height="24">
                        <Path Fill="White" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                    </Canvas>
                </Viewbox>
                
                <TextBlock x:Name="ErrorText" 
                          Style="{StaticResource IndicatorText}"
                          Text="Error cargando página"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

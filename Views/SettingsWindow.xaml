<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ComicReader.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ComicReader.ViewModels"
        Title="Configuración — Percy's Library"
        Height="720" Width="960"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Surface.Base.Brush}"
        FontFamily="{DynamicResource AppFontFamily}">

    <Window.Resources>
        <vm:SettingsViewModel x:Key="SettingsVM" />

        <!-- Etiqueta de fila de configuración -->
        <Style x:Key="SettingsRowLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary.Brush}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="320"/>
        </Style>

        <!-- Caption auxiliar bajo una fila -->
        <Style x:Key="SettingsRowCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary.Brush}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Header de seccion dentro de una pestana -->
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource Text.Title}">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Title}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Card de seccion: usa el sistema, padding aireado -->
        <Style x:Key="SettingsCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Filas: stack horizontal con respiración consistente -->
        <Style x:Key="SettingsRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </Window.Resources>

    <Grid DataContext="{StaticResource SettingsVM}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="32,24,32,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Configuración"
                       Style="{DynamicResource Text.Title}"
                       FontSize="{DynamicResource FontSize.Display}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Cancelar" Style="{DynamicResource Button.Secondary}" Click="Close_Click" Margin="0,0,8,0"/>
                <Button Content="Aplicar" Style="{DynamicResource Button.Primary}" Click="Apply_Click"/>
            </StackPanel>
        </Grid>

        <!-- TABS -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="32,0,32,16">
            <ToggleButton x:Name="TabLectura" Content="Lectura" Style="{DynamicResource Toggle.Chip}" IsChecked="True" Click="Tab_Click" Margin="0,0,4,0"/>
            <ToggleButton x:Name="TabApariencia" Content="Apariencia" Style="{DynamicResource Toggle.Chip}" Click="Tab_Click" Margin="0,0,4,0"/>
            <ToggleButton x:Name="TabBiblioteca" Content="Biblioteca" Style="{DynamicResource Toggle.Chip}" Click="Tab_Click"/>
        </StackPanel>

        <!-- CONTENIDO -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="32,0,32,0">
            <Grid>
                <!-- ====== LECTURA ====== -->
                <StackPanel x:Name="Panel_Lectura">
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Modo y dirección" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Modo de lectura por defecto" Style="{StaticResource SettingsRowLabel}"/>
                                <ComboBox x:Name="ReadingModeCombo" Width="240" SelectionChanged="ReadingModeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Continuo (scroll vertical)" Tag="Continuous"/>
                                    <ComboBoxItem Content="Paginado" Tag="PageByPage"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Dirección de lectura" Style="{StaticResource SettingsRowLabel}"/>
                                <ComboBox x:Name="ReadingDirectionCombo" Width="240" SelectionChanged="ReadingDirectionCombo_SelectionChanged">
                                    <ComboBoxItem Content="Izquierda → Derecha" Tag="LeftToRight"/>
                                    <ComboBoxItem Content="Derecha → Izquierda (manga)" Tag="RightToLeft"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Animación al pasar página" Style="{StaticResource SettingsRowLabel}"/>
                                <ComboBox x:Name="PageTurnAnimationCombo" Width="240" SelectionChanged="PageTurnAnimationCombo_SelectionChanged">
                                    <ComboBoxItem Content="Ninguna" Tag="None"/>
                                    <ComboBoxItem Content="Fundido" Tag="Fade"/>
                                    <ComboBoxItem Content="Deslizar" Tag="Slide"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Zoom y navegación" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Zoom por defecto" Style="{StaticResource SettingsRowLabel}"/>
                                <Slider Minimum="50" Maximum="200" Value="{Binding AppSettings.DefaultZoomPercent, Mode=TwoWay}" Width="240" Style="{DynamicResource Slider.Default}"/>
                                <TextBlock Text="{Binding AppSettings.DefaultZoomPercent}" Width="40" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource Text.Secondary.Brush}"/>
                                <TextBlock Text="%" VerticalAlignment="Center" Foreground="{DynamicResource Text.Secondary.Brush}"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Sensibilidad del scroll" Style="{StaticResource SettingsRowLabel}"/>
                                <Slider Minimum="0.2" Maximum="2.0" Value="{Binding AppSettings.ScrollSensitivity, Mode=TwoWay}" Width="240" Style="{DynamicResource Slider.Default}"/>
                                <TextBlock Text="{Binding AppSettings.ScrollSensitivity, StringFormat={}{0:F2}}" Width="50" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource Text.Secondary.Brush}"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Mostrar número de página" Style="{StaticResource SettingsRowLabel}"/>
                                <CheckBox IsChecked="{Binding AppSettings.ShowPageNumbers, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Auto-recortar bordes blancos" Style="{StaticResource SettingsRowLabel}"/>
                                <CheckBox IsChecked="{Binding AppSettings.AutoCropWhiteBorders, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Recorta automaticamente el borde blanco de cada pagina para que la imagen ocupe mas pantalla. Si una pagina no tiene borde blanco evidente no se toca. Off por defecto."
                                       Style="{StaticResource SettingsRowCaption}" Margin="0,0,0,8"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Interfaz del lector" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Auto-ocultar barra en modo ventana" Style="{StaticResource SettingsRowLabel}"/>
                                <CheckBox VerticalAlignment="Center"
                                          IsChecked="{Binding AppSettings.HideOverlayOnlyInImmersive, Mode=TwoWay, Converter={StaticResource InverseBoolConverter}}"/>
                            </StackPanel>
                            <TextBlock Text="Cuando esta activado, la barra se desvanece tras unos segundos en modo ventana. Si esta desactivado, solo se oculta en pantalla completa inmersiva. Mover el mouse siempre la trae de vuelta."
                                       Style="{StaticResource SettingsRowCaption}" Margin="0,0,0,8"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Demora antes de ocultar (s)" Style="{StaticResource SettingsRowLabel}"/>
                                <Slider Minimum="1" Maximum="10" Value="{Binding AppSettings.HideOverlayDelaySeconds, Mode=TwoWay}" Width="240" Style="{DynamicResource Slider.Default}"/>
                                <TextBlock Text="{Binding AppSettings.HideOverlayDelaySeconds, StringFormat={}{0:F0}}" Width="40" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource Text.Secondary.Brush}"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Atajos de teclado" Style="{StaticResource SettingsRowLabel}"/>
                                <Button Content="Editar atajos" Style="{DynamicResource Button.Secondary}" Command="{Binding ConfigureShortcutsCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== APARIENCIA ====== -->
                <StackPanel x:Name="Panel_Apariencia" Visibility="Collapsed">
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Tema" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Tema de la aplicación" Style="{StaticResource SettingsRowLabel}"/>
                                <ComboBox x:Name="ThemeCombo"
                                          ItemsSource="{Binding ThemeInfos}"
                                          DisplayMemberPath="Name"
                                          SelectedItem="{Binding SelectedThemeInfo, Mode=TwoWay}"
                                          Width="240"
                                          SelectionChanged="ThemeCombo_SelectionChanged"/>
                            </StackPanel>
                            <TextBlock Text="Los cambios se previsualizan al instante. Pulsá Aplicar para guardarlos."
                                       Style="{StaticResource SettingsRowCaption}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Tipografía e interfaz" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Tamaño de la interfaz" Style="{StaticResource SettingsRowLabel}"/>
                                <ComboBox x:Name="UIScaleCombo" Width="240" SelectionChanged="UIScaleCombo_SelectionChanged">
                                    <ComboBoxItem Content="Pequeño" Tag="Small"/>
                                    <ComboBoxItem Content="Mediano" Tag="Medium"/>
                                    <ComboBoxItem Content="Grande" Tag="Large"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Modo nocturno" Style="{StaticResource SettingsRowLabel}"/>
                                <CheckBox IsChecked="{Binding AppSettings.IsNightMode, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Aplica un filtro suave para reducir la fatiga visual al leer en entornos oscuros."
                                       Style="{StaticResource SettingsRowCaption}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Personalización" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Tu nombre" Style="{StaticResource SettingsRowLabel}"/>
                                <TextBox Text="{Binding AppSettings.UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Width="240"
                                         Style="{DynamicResource Input.Text}"/>
                            </StackPanel>
                            <TextBlock Text="Si lo configurás, Percy te saluda en el inicio según la hora del día. Vacío = sin saludo."
                                       Style="{StaticResource SettingsRowCaption}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== BIBLIOTECA ====== -->
                <StackPanel x:Name="Panel_Biblioteca" Visibility="Collapsed">
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Carpeta y sesión" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Carpeta por defecto" Style="{StaticResource SettingsRowLabel}"/>
                                <TextBlock Text="{Binding AppSettings.DefaultComicsFolder}" Width="280" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource Text.Secondary.Brush}" VerticalAlignment="Center"/>
                                <Button Content="Cambiar" Style="{DynamicResource Button.Secondary}" Command="{Binding ChangeFolderCommand}" Margin="12,0,0,0"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Recordar última sesión" Style="{StaticResource SettingsRowLabel}"/>
                                <CheckBox IsChecked="{Binding AppSettings.RememberLastSession, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Abrir último cómic al iniciar" Style="{StaticResource SettingsRowLabel}"/>
                                <CheckBox IsChecked="{Binding AppSettings.OpenLastOnStartup, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Mostrar miniaturas laterales" Style="{StaticResource SettingsRowLabel}"/>
                                <CheckBox IsChecked="{Binding AppSettings.ThumbnailsVisible, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Rendimiento" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Precarga de páginas adyacentes" Style="{StaticResource SettingsRowLabel}"/>
                                <CheckBox IsChecked="{Binding AppSettings.EnableEagerPreload, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Tamaño máximo de caché (MB)" Style="{StaticResource SettingsRowLabel}"/>
                                <TextBox Text="{Binding AppSettings.EagerPreloadDiskMaxMB, Mode=TwoWay}" Width="160" Style="{DynamicResource Input.Text}"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <Button Content="Limpiar caché" Style="{DynamicResource Button.Secondary}" Command="{Binding ClearCacheCommand}"/>
                                <Button Content="Optimizar ahora" Style="{DynamicResource Button.Secondary}" Command="{Binding OptimizeCommand}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="ComicVine (opcional)" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="Habilitar enriquecimiento de metadatos" Style="{StaticResource SettingsRowLabel}"/>
                                <CheckBox IsChecked="{Binding AppSettings.EnableComicVineEnrichment, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <TextBlock Text="API key" Style="{StaticResource SettingsRowLabel}"/>
                                <TextBox Text="{Binding AppSettings.ComicVineApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Width="320"
                                         Style="{DynamicResource Input.Text}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SettingsRowCaption}"
                                       Text="Obtené tu key gratis en comicvine.gamespot.com/api/. Si la dejás vacía, la app funciona 100% offline."/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Datos y respaldo" Style="{StaticResource SettingsSectionTitle}"/>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <Button Content="Exportar ajustes" Style="{DynamicResource Button.Secondary}" Click="Export_Click"/>
                                <Button Content="Importar ajustes" Style="{DynamicResource Button.Secondary}" Click="Import_Click" Margin="8,0,0,0"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsRow}">
                                <Button Content="Restaurar valores por defecto" Style="{DynamicResource Button.Danger}" Command="{Binding RestoreDefaultsCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Foreground="{DynamicResource Text.Secondary.Brush}"
                           FontSize="{DynamicResource FontSize.Caption}"
                           VerticalAlignment="Center"
                           Text="Percy's Library · v1.0.0"/>
                <Button DockPanel.Dock="Right"
                        Content="Acerca de"
                        Style="{DynamicResource Button.Secondary}"
                        Command="{Binding ViewCreditsCommand}"
                        HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>

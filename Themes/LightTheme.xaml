<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Colores principales para modo claro -->
    <Color x:Key="BackgroundColor">#F7FAFC</Color>
    <Color x:Key="HeaderTextColor">#1F2937</Color>
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="SecondaryColor">#E6EEF8</Color>
    <Color x:Key="TextColor">#0F172A</Color>
    <Color x:Key="FooterBackground">#F1F5F9</Color>
    <Color x:Key="HeaderBackground">#FFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="{StaticResource HeaderTextColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#475569"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1E40AF"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#EEF2FF"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#EEF2FF"/>
    <SolidColorBrush x:Key="CurrentPageBorderBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E6E7EA"/>
    <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#80000000"/>
    <SolidColorBrush x:Key="BookmarkBrush" Color="#F97316"/>
</ResourceDictionary>
<Window x:Class="ComicReader.Views.EditCollectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ComicReader.Views.Controls"
    Title="Editar Colección" Height="360" Width="520" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

    <TextBlock Text="Nombre" FontWeight="Bold" />
    <TextBox x:Name="NameBox" Grid.Row="1" Margin="0,6,0,0" AutomationProperties.Name="Nombre de la colección" />

        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <TextBlock Text="Descripción" FontWeight="Bold" />
            <TextBox x:Name="DescBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,6,0,0" AutomationProperties.Name="Descripción de la colección" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Seleccionar portada..." Click="SelectCover_Click" AutomationProperties.Name="Seleccionar portada" />
                <TextBlock x:Name="CoverPathText" Margin="8,6,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Width="300" AutomationProperties.Name="Ruta de la portada" />
            </StackPanel>

            <TextBlock Text="Cómics en la colección" FontWeight="Bold" Margin="0,12,0,0" />
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="Añadir cómics..." Click="AddComics_Click" AutomationProperties.Name="Añadir cómics" />
                <Button Content="Quitar seleccionados" Click="RemoveSelected_Click" Margin="8,0,0,0" AutomationProperties.Name="Quitar cómics seleccionados" />
                <Button x:Name="UndoButton" Content="Deshacer" Click="Undo_Click" Margin="8,0,0,0" IsEnabled="False" AutomationProperties.Name="Deshacer eliminación" />
            </StackPanel>
            <ListBox x:Name="ItemsList" Height="160" Margin="0,8,0,0" SelectionMode="Extended" AutomationProperties.Name="Lista de cómics"
                     AllowDrop="True" PreviewMouseLeftButtonDown="ItemsList_PreviewMouseLeftButtonDown" PreviewMouseMove="ItemsList_PreviewMouseMove" Drop="ItemsList_Drop" DragOver="ItemsList_DragOver">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="140" Height="200" Background="White" Margin="8" CornerRadius="8" Padding="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <controls:ProgressComicItem ThumbnailPath="{Binding ThumbPath}" Title="{Binding Title}" Grid.Row="0" />
                                <TextBlock Grid.Row="1" Text="{Binding Title}" TextTrimming="CharacterEllipsis" Width="120" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Width="84" Margin="6" Click="Cancel_Click" />
            <Button Content="Guardar" Width="84" Margin="6" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>

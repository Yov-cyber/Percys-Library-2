<UserControl x:Class="ComicReader.Views.FavoritesSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ComicReader.ViewModels"
             xmlns:models="clr-namespace:ComicReader.Models"
             xmlns:local="clr-namespace:ComicReader.Views">
    <UserControl.Resources>
        <DataTemplate x:Key="FavoriteItemTemplate">
            <Border Padding="8" Margin="4" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Width="64" Height="90" Source="{Binding Thumbnail}" Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           RenderOptions.EdgeMode="Aliased" Grid.Column="0" />
                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{Binding Author}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="8" Margin="0,8,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                        <Button Content="Abrir" Command="{Binding OpenCommand}" Margin="0,0,0,4"/>
                        <Button Content="Quitar" Command="{Binding RemoveCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

    <!-- Left: Collections list -->
    <StackPanel Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}" Margin="12">
            <TextBlock Text="Colecciones" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
            <ListBox ItemsSource="{Binding Collections}" SelectedItem="{Binding SelectedCollection}" DisplayMemberPath="Name" Height="300" Margin="0,8,0,8"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Nueva" Command="{Binding AddCollectionCommand}" Margin="0,0,6,0"/>
                <Button Content="Eliminar" Command="{Binding RemoveCollectionCommand}"/>
            </StackPanel>
            <Separator Margin="0,12"/>
            <Button Content="Añadir favorito (ejemplo)" Command="{Binding AddFavoriteCommand}"/>
        </StackPanel>

    <!-- Right: Favorites grid for selected collection -->
    <ScrollViewer Grid.Column="1" Margin="12">
            <ItemsControl ItemsSource="{Binding SelectedCollection.Items}" ItemTemplate="{StaticResource FavoriteItemTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>

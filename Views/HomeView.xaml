<UserControl x:Class="ComicReader.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ComicReader.Views"
             xmlns:conv="clr-namespace:ComicReader.Converters"
             xmlns:controls="clr-namespace:ComicReader.Controls"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280"
             Background="{DynamicResource Surface.Base.Brush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
            <conv:NullToVisibleConverter x:Key="NullToVisibleConverter"/>
            <conv:CoverPathOrThumbnailConverter x:Key="CoverPathOrThumbnailConverter"/>

            <!-- Barra de progreso ultra delgada para overlay sobre portada -->
            <Style x:Key="CoverProgressBar" TargetType="ProgressBar"
                   BasedOn="{StaticResource Progress.Default}">
                <Setter Property="Height" Value="3"/>
                <Setter Property="Background" Value="#66000000"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="VerticalAlignment" Value="Bottom"/>
            </Style>

            <!-- ListBoxItem transparente para que el ListBox quede como contenedor
                 puro de virtualizacion. Toda la interaccion (click, hover, contexto)
                 vive dentro de cada DataTemplate (la propia card del cover).
                 Sin esto, ListBox impone padding/background/seleccion azul que
                 contradicen el sistema visual. -->
            <Style x:Key="HomeCardListItem" TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Cover card: portada protagonista, progreso integrado en la portada,
                 título y meta debajo. Sin sombra, sin scale, sin gradiente decorativo.
                 Toda la card es clickeable; menú contextual con acciones secundarias. -->
            <DataTemplate x:Key="ComicCoverCardTemplate">
                <Border Width="184" Margin="0,0,16,16" Cursor="Hand"
                        Background="{DynamicResource Surface.Raised.Brush}"
                        BorderBrush="{DynamicResource Border.Subtle.Brush}"
                        BorderThickness="1" CornerRadius="8"
                        SnapsToDevicePixels="True"
                        MouseLeftButtonUp="OpenRecentComic_Click">
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Leer"
                                      Command="{Binding DataContext.OpenComicCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding FilePath}"/>
                            <MenuItem Header="Mostrar en carpeta"
                                      Command="{Binding DataContext.ShowInFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding FilePath}"/>
                            <Separator/>
                            <MenuItem Header="Quitar de la lista"
                                      Command="{Binding DataContext.RemoveRecentComicCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding FilePath}"/>
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Portada -->
                        <Border Grid.Row="0" Height="266"
                                Background="{DynamicResource Surface.Overlay.Brush}"
                                CornerRadius="8,8,0,0" ClipToBounds="True">
                            <Grid>
                                <!-- Stretch=Uniform: respeta proporcion original sin recortar.
                                     El comic tiene ratio ~2:3 = 0.667; el contenedor 184x266 ratio 0.692,
                                     diferencia minima => bandas casi imperceptibles.
                                     HighQuality + Aliased reducen el blur en el escalado. -->
                                <Image Stretch="Uniform" SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased">
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource CoverPathOrThumbnailConverter}">
                                            <Binding Path="CoverPath"/>
                                            <Binding Path="CoverThumbnail"/>
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>

                                <!-- Barra de progreso integrada en la portada (3px, acento).
                                     Se ve directamente, sin texto adicional. -->
                                <ProgressBar Style="{StaticResource CoverProgressBar}"
                                             Minimum="0" Maximum="100"
                                             Value="{Binding ProgressPercent, Mode=OneWay}"/>
                            </Grid>
                        </Border>

                        <!-- Título + meta -->
                        <StackPanel Grid.Row="1" Margin="12,10,12,12">
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="{DynamicResource Text.Primary.Brush}"
                                       FontFamily="{DynamicResource AppFontFamily}"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"/>
                            <TextBlock Foreground="{DynamicResource Text.Secondary.Brush}"
                                       FontFamily="{DynamicResource AppFontFamily}"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       Margin="0,4,0,0">
                                <Run Text="{Binding LastPage, Mode=OneWay}"/>
                                <Run Text="/"/>
                                <Run Text="{Binding PageCount, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- Folder item card (carpeta explorada): mismo lenguaje visual. -->
            <DataTemplate x:Key="FolderItemCardTemplate">
                <Border Width="184" Margin="0,0,16,16" Cursor="Hand"
                        Background="{DynamicResource Surface.Raised.Brush}"
                        BorderBrush="{DynamicResource Border.Subtle.Brush}"
                        BorderThickness="1" CornerRadius="8"
                        SnapsToDevicePixels="True"
                        MouseLeftButtonUp="OpenFolderItem_Click">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Height="266"
                                Background="{DynamicResource Surface.Overlay.Brush}"
                                CornerRadius="8,8,0,0" ClipToBounds="True">
                            <Grid>
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased"
                                       Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                <TextBlock Text="📁" FontSize="56"
                                           Foreground="{DynamicResource Text.Secondary.Brush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding IsFolder, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="1" Margin="12,10,12,12">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource Text.Primary.Brush}"
                                       FontFamily="{DynamicResource AppFontFamily}"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Foreground="{DynamicResource Text.Secondary.Brush}"
                                           FontFamily="{DynamicResource AppFontFamily}"
                                           FontSize="{DynamicResource FontSize.Caption}"
                                           Visibility="{Binding IsFolder, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Run Text="{Binding ComicCount, Mode=OneWay}"/>
                                    <Run Text=" cómics"/>
                                </TextBlock>
                                <TextBlock Foreground="{DynamicResource Text.Secondary.Brush}"
                                           FontFamily="{DynamicResource AppFontFamily}"
                                           FontSize="{DynamicResource FontSize.Caption}"
                                           Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <Run Text="{Binding Extension, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============== HEADER (pestañas + acciones secundarias) ============== -->
        <Grid Grid.Row="0" Margin="32,24,32,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Pestañas (visible cuando NO se está navegando una carpeta) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding CurrentFolderPath, Converter={StaticResource NullToVisibleConverter}}">
                <ToggleButton x:Name="TabContinue" IsChecked="True" Click="TabContinue_Click"
                              Style="{StaticResource Toggle.Chip}">
                    <TextBlock Text="Continuar leyendo"/>
                </ToggleButton>
                <ToggleButton x:Name="TabCompleted" IsChecked="False" Click="TabCompleted_Click"
                              Style="{StaticResource Toggle.Chip}" Margin="6,0,0,0">
                    <TextBlock Text="Completados"/>
                </ToggleButton>
            </StackPanel>

            <!-- Breadcrumb cuando se navega una carpeta -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding CurrentFolderPath, Converter={StaticResource NullToCollapsedConverter}}">
                <Button Style="{StaticResource Button.Icon}" Click="BackToHome_Click" ToolTip="Volver a la biblioteca">
                    <TextBlock Text="⟵" FontSize="14"/>
                </Button>
                <Button Style="{StaticResource Button.Icon}" Click="UpFolder_Click" ToolTip="Subir un nivel" Margin="4,0,0,0">
                    <TextBlock Text="⬆" FontSize="14"/>
                </Button>
                <TextBlock Text="{Binding CurrentFolderPath}"
                           Foreground="{DynamicResource Text.Secondary.Brush}"
                           FontFamily="{DynamicResource AppFontFamily}"
                           FontSize="{DynamicResource FontSize.Caption}"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Acciones secundarias: solo adquisicion de contenido (archivo / carpeta).
                 Colecciones, Estadisticas y Logros se acceden ahora desde el sidebar
                 permanente de MainWindow. -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource Button.Icon}" Click="OpenFile_Click" ToolTip="Abrir archivo">
                    <TextBlock Text="📄" FontSize="16"/>
                </Button>
                <Button Style="{StaticResource Button.Icon}" Click="OpenFolder_Click" ToolTip="Explorar carpeta" Margin="4,0,0,0">
                    <TextBlock Text="📂" FontSize="16"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ============== CONTENIDO PRINCIPAL ============== -->
        <Grid Grid.Row="1">

            <!-- Estado vacío (sólo cuando NO hay items y NO hay carpeta navegada) -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="420" Margin="32">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasAnyContinueItems}" Value="False"/>
                                    <Condition Binding="{Binding CurrentFolderPath, Converter={StaticResource NullToCollapsedConverter}}" Value="Collapsed"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Tu biblioteca está vacía"
                           Style="{StaticResource Text.Title}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Abre un archivo o explora una carpeta para empezar a leer."
                           Style="{StaticResource Text.Body}"
                           Foreground="{DynamicResource Text.Secondary.Brush}"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,8,0,24" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Style="{StaticResource Button.Primary}" Click="OpenFile_Click" Content="Abrir archivo"/>
                    <Button Style="{StaticResource Button.Secondary}" Click="OpenFolder_Click"
                            Content="Explorar carpeta" Margin="8,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Biblioteca (cuando hay items y NO hay carpeta navegada).

                 Sin ScrollViewer externo: las ListBox internas ya tienen su
                 propio ScrollViewer y necesitan viewport finito para que la
                 virtualizacion funcione. Un ScrollViewer externo forzaria
                 altura infinita y destruiria la virtualizacion. -->
            <Grid Margin="32,0,32,32">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasAnyContinueItems}" Value="True"/>
                                    <Condition Binding="{Binding CurrentFolderPath, Converter={StaticResource NullToCollapsedConverter}}" Value="Collapsed"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid>
                    <!-- Continuar leyendo.

                         Se usa ListBox (no ItemsControl) a proposito: un ListBox
                         instancia internamente un ScrollViewer y bridgeaa
                         CanContentScroll=True hacia el panel virtualizante, de
                         modo que VirtualizingWrapPanel.MeasureOverride recibe el
                         viewport real en lugar de Infinity (lo cual crasheaba
                         cuando VirtualizingWrapPanel quedaba dentro de un
                         ScrollViewer externo, como ocurria con ItemsControl).
                         El ItemContainerStyle neutraliza el chrome de ListBox
                         para que la card de cada cover sea el unico elemento
                         visible. -->
                    <ListBox ItemsSource="{Binding RecentComics}"
                             ItemTemplate="{StaticResource ComicCoverCardTemplate}"
                             ItemContainerStyle="{StaticResource HomeCardListItem}"
                             Visibility="{Binding ElementName=TabContinue, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}"
                             Background="Transparent" BorderThickness="0"
                             Padding="0" Margin="0"
                             SelectionMode="Single"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- ItemWidth/Height incluyen el Margin de la card (184+16, ~340 alto). -->
                                <controls:VirtualizingWrapPanel ItemWidth="200" ItemHeight="340"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>

                    <!-- Completados -->
                    <ListBox ItemsSource="{Binding CompletedComics}"
                             ItemTemplate="{StaticResource ComicCoverCardTemplate}"
                             ItemContainerStyle="{StaticResource HomeCardListItem}"
                             Visibility="{Binding ElementName=TabCompleted, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}"
                             Background="Transparent" BorderThickness="0"
                             Padding="0" Margin="0"
                             SelectionMode="Single"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingWrapPanel ItemWidth="200" ItemHeight="340"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </Grid>
            </Grid>

            <!-- Explorador de carpeta. Mismo patron ListBox para virtualizar
                 bien. Placeholder "carpeta vacia" via DataTrigger sobre el
                 Template del ListBox. -->
            <Grid Margin="32,0,32,32"
                  Visibility="{Binding CurrentFolderPath, Converter={StaticResource NullToCollapsedConverter}}">
                <ListBox ItemsSource="{Binding FolderContents}"
                         ItemTemplate="{StaticResource FolderItemCardTemplate}"
                         ItemContainerStyle="{StaticResource HomeCardListItem}"
                         Background="Transparent" BorderThickness="0"
                         Padding="0" Margin="0"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:VirtualizingWrapPanel ItemWidth="200" ItemHeight="340"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
                <TextBlock Text="Esta carpeta está vacía."
                           Foreground="{DynamicResource Text.Secondary.Brush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,80,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FolderContents.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

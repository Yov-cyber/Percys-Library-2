<UserControl x:Class="ComicReader.Views.Controls.ColorPickerSimple"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ComicReader.Converters"
             Height="28" Width="220">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="120" />
      <ColumnDefinition Width="24" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <TextBox Grid.Column="0" x:Name="HexBox" Text="#FFAA00" />
    <Border Grid.Column="1" Width="24" Height="24" Background="{Binding Text, ElementName=HexBox, Converter={StaticResource StringToBrushConverter}}" Margin="8,0,0,0" />
  <Button Grid.Column="2" Content="Pick" Width="48" Margin="8,0,0,0" Click="PickClicked" />
  </Grid>
</UserControl>

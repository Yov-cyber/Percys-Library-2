<UserControl x:Class="ComicReader.Views.Controls.CollectionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ComicReader.Views.Controls"
             xmlns:controls="clr-namespace:ComicReader.Views.Controls"
             Height="160" Width="260"
             Focusable="True">
    <Border Background="{DynamicResource CS_CardBackground}" CornerRadius="10" Padding="12" Margin="8" SnapsToDevicePixels="True"
        AutomationProperties.Name="{Binding Name, FallbackValue=Colección}"
        AutomationProperties.HelpText="{Binding Description}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Cover preview -->
            <Border Grid.Column="0" Background="#F6F7FB" CornerRadius="6" Width="96" Height="128" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Use ProgressComicItem for lazy load if there's a thumbnail, else placeholder -->
                <controls:ProgressComicItem ThumbnailPath="{Binding Items[0].ThumbPath}" Title="{Binding Name}" Width="96" Height="128" />
            </Border>

            <!-- Info and actions -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <DockPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource CS_TextPrimary}" DockPanel.Dock="Left" VerticalAlignment="Top" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <Button Width="28" Height="28" Margin="4,0,0,0" Content="✎" ToolTip="Editar" Click="Edit_Click" AutomationProperties.Name="Editar colección" />
                        <Button Width="28" Height="28" Margin="4,0,0,0" Content="⎘" ToolTip="Duplicar" Click="Duplicate_Click" AutomationProperties.Name="Duplicar colección" />
                        <Button Width="28" Height="28" Margin="4,0,0,0" Content="🗑" ToolTip="Eliminar" Click="Delete_Click" AutomationProperties.Name="Eliminar colección" />
                    </StackPanel>
                </DockPanel>

                <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis" Opacity="0.8" Margin="0,6,0,6" />

                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,8,0,0">
                    <TextBlock Text="{Binding Count, StringFormat='{}{0} cómics'}" Foreground="{DynamicResource CS_TextSecondary}" FontSize="12" VerticalAlignment="Center" />
                    <Button Content="Abrir" Margin="8,0,0,0" Padding="6,2" Click="Edit_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

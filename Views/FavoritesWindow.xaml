<Window x:Class="ComicReader.Views.FavoritesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biblioteca de Cómics Percy 📚" 
        Width="1400" Height="900"
        MinWidth="1200" MinHeight="800"
        WindowStartupLocation="Manual"
        WindowState="Normal"
        Left="100" Top="50"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- ============================================ -->
        <!-- COMIC BOOK STYLE COLORS - Usando tema global -->
        <!-- ============================================ -->
        <SolidColorBrush x:Key="ComicRed" Color="#FF3131"/>
        <SolidColorBrush x:Key="ComicYellow" Color="#FFD700"/>
        <SolidColorBrush x:Key="ComicBlue" Color="#4169E1"/>
        <SolidColorBrush x:Key="ComicPurple" Color="#9370DB"/>
        <SolidColorBrush x:Key="ComicGreen" Color="#32CD32"/>
        <SolidColorBrush x:Key="ComicOrange" Color="#FF8C00"/>
        <!-- Colores de tema aplicados dinámicamente -->
        <SolidColorBrush x:Key="DarkBg" Color="{DynamicResource WindowBackgroundColor}"/>
        <SolidColorBrush x:Key="MediumBg" Color="{DynamicResource PanelBackgroundColor}"/>
        <SolidColorBrush x:Key="AccentBg" Color="{DynamicResource HeaderBackgroundColor}"/>
        <SolidColorBrush x:Key="TextLight" Color="{DynamicResource TextColor}"/>
        <SolidColorBrush x:Key="TextMuted" Color="{DynamicResource SecondaryTextColor}"/>

        <!-- ============================================ -->
        <!-- COMIC BOOK SHADOWS & EFFECTS -->
        <!-- ============================================ -->
        <DropShadowEffect x:Key="ComicShadow" BlurRadius="20" ShadowDepth="5" Opacity="0.4" Color="#000000"/>
        <DropShadowEffect x:Key="HoverGlow" BlurRadius="25" ShadowDepth="0" Opacity="0.8" Color="#FFD700"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Opacity="0.3" Color="#000000"/>

        <!-- ============================================ -->
        <!-- COMIC CARD STYLE (Dynamic Hover) -->
        <!-- ============================================ -->
        <Style x:Key="ComicCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource MediumBg}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" 
                                                 To="1.08" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" 
                                                 To="1.08" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" 
                                                 To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" 
                                                 To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                    <Setter Property="Effect" Value="{StaticResource HoverGlow}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================ -->
        <!-- COMIC BUTTON STYLE -->
        <!-- ============================================ -->
        <Style x:Key="ComicButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ComicYellow}"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="#000000"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ComicOrange}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryComicButtonStyle" BasedOn="{StaticResource ComicButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- ============================================ -->
        <!-- SEARCH BOX STYLE -->
        <!-- ============================================ -->
        <Style x:Key="ComicSearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource MediumBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ComicYellow}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================ -->
        <!-- STATS CARD STYLE -->
        <!-- ============================================ -->
        <Style x:Key="StatsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AccentBg}"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{StaticResource ComicYellow}"/>
        </Style>

    </Window.Resources>

    <!-- ============================================ -->
    <!-- MAIN CONTENT (Ventana Windows Normal) -->
    <!-- ============================================ -->
    <Grid Background="{StaticResource DarkBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Stats Dashboard -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- ============================================ -->
        <!-- PANEL DE ESTADÍSTICAS (Estilo Cómic) -->
        <!-- ============================================ -->
        <Border Grid.Row="0" 
                Background="{StaticResource DarkBg}" 
                Padding="20,15">
            <UniformGrid Rows="1" Columns="4">
                <!-- Total Cómics -->
                <Border Style="{StaticResource StatsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="📖 TOTAL" 
                                   FontSize="14" 
                                   Foreground="{StaticResource ComicYellow}" 
                                   FontWeight="Black"
                                   FontFamily="Arial Black"/>
                        <TextBlock x:Name="TotalComicsText" 
                                   Text="0" 
                                   FontSize="42" 
                                   FontWeight="Black" 
                                   Foreground="{StaticResource TextLight}" 
                                   Margin="0,8,0,0"
                                   FontFamily="Impact"/>
                    </StackPanel>
                </Border>

                <!-- Completados -->
                <Border Style="{StaticResource StatsCardStyle}" BorderBrush="{StaticResource ComicGreen}">
                    <StackPanel>
                        <TextBlock Text="✅ COMPLETADOS" 
                                   FontSize="14" 
                                   Foreground="{StaticResource ComicGreen}" 
                                   FontWeight="Black"
                                   FontFamily="Arial Black"/>
                        <TextBlock x:Name="CompletedComicsText" 
                                   Text="0" 
                                   FontSize="42" 
                                   FontWeight="Black" 
                                   Foreground="{StaticResource TextLight}" 
                                   Margin="0,8,0,0"
                                   FontFamily="Impact"/>
                    </StackPanel>
                </Border>

                <!-- Leyendo -->
                <Border Style="{StaticResource StatsCardStyle}" BorderBrush="{StaticResource ComicBlue}">
                    <StackPanel>
                        <TextBlock Text="📚 LEYENDO" 
                                   FontSize="14" 
                                   Foreground="{StaticResource ComicBlue}" 
                                   FontWeight="Black"
                                   FontFamily="Arial Black"/>
                        <TextBlock x:Name="ReadingComicsText" 
                                   Text="0" 
                                   FontSize="42" 
                                   FontWeight="Black" 
                                   Foreground="{StaticResource TextLight}" 
                                   Margin="0,8,0,0"
                                   FontFamily="Impact"/>
                    </StackPanel>
                </Border>

                <!-- Valoración -->
                <Border Style="{StaticResource StatsCardStyle}" BorderBrush="{StaticResource ComicOrange}">
                    <StackPanel>
                        <TextBlock Text="⭐ VALORACIÓN" 
                                       FontSize="14" 
                                       Foreground="{StaticResource ComicOrange}" 
                                       FontWeight="Black"
                                       FontFamily="Arial Black"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock x:Name="AverageRatingText" 
                                           Text="0.0" 
                                           FontSize="42" 
                                           FontWeight="Black" 
                                           Foreground="{StaticResource TextLight}"
                                           FontFamily="Impact"/>
                                <TextBlock Text="★" 
                                           FontSize="32" 
                                           Foreground="{StaticResource ComicYellow}" 
                                           VerticalAlignment="Center" 
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ============================================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <!-- Barra lateral de Colecciones -->
                <ColumnDefinition Width="*"/>
                <!-- Galería de Cómics -->
            </Grid.ColumnDefinitions>

            <!-- ============================================ -->
            <!-- BARRA LATERAL DE COLECCIONES -->
            <!-- ============================================ -->
            <Border Grid.Column="0" 
                    Background="{StaticResource MediumBg}" 
                    BorderThickness="0,0,2,0" 
                    BorderBrush="{StaticResource ComicYellow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado + Acciones -->
                    <StackPanel Grid.Row="0" Margin="20,20,20,15">
                        <TextBlock Text="🗂️ COLECCIONES" 
                                   FontSize="22" 
                                   FontWeight="Black" 
                                   Foreground="{StaticResource ComicYellow}"
                                   FontFamily="Arial Black"/>
                        
                        <Button Content="+ NUEVA COLECCIÓN" 
                                Style="{StaticResource ComicButtonStyle}" 
                                Click="CreateCollection_Click" 
                                Margin="0,15,0,0" 
                                HorizontalAlignment="Stretch"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Button Content="📤 Exportar" 
                                    Style="{StaticResource SecondaryComicButtonStyle}" 
                                    Click="ExportCollections_Click" 
                                    Margin="0,0,5,0"/>
                            <Button Content="📥 Importar" 
                                    Style="{StaticResource SecondaryComicButtonStyle}" 
                                    Click="ImportCollections_Click" 
                                    Margin="5,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                        <!-- Collections List -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,0">
                            <ListBox x:Name="CollectionsListBox" 
                                     Background="Transparent"
                                     BorderThickness="0"
                                     SelectionChanged="CollectionsListBox_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="10" 
                                                            Padding="15,12" 
                                                            Margin="8,4"
                                                            BorderThickness="2"
                                                            BorderBrush="Transparent">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBg}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource DarkBg}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid.ContextMenu>
                                                <ContextMenu Background="{StaticResource MediumBg}" 
                                                             Foreground="{StaticResource TextLight}">
                                                    <MenuItem Header="✏️ Renombrar" Click="RenameCollection_Click"/>
                                                    <MenuItem Header="📋 Duplicar" Click="DuplicateCollection_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="🗑️ Eliminar" Click="DeleteCollection_Click"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>

                                            <Ellipse Grid.Column="0" 
                                                     Width="16" 
                                                     Height="16" 
                                                     Fill="{Binding Color}" 
                                                     Margin="0,0,12,0"
                                                     Stroke="{StaticResource ComicYellow}"
                                                     StrokeThickness="2"/>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontWeight="Bold" 
                                                           FontSize="15" 
                                                           Foreground="{StaticResource TextLight}"/>
                                                <TextBlock FontSize="12" 
                                                           Foreground="{StaticResource TextMuted}" 
                                                           Margin="0,4,0,0">
                                                    <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                                                    <Run Text=" cómics"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ============================================ -->
                <!-- GALERÍA DE CÓMICS (Dinámica e Interactiva) -->
                <!-- ============================================ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Toolbar -->
                        <RowDefinition Height="*"/>
                        <!-- Gallery -->
                    </Grid.RowDefinitions>

                    <!-- Barra de Herramientas -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource MediumBg}" 
                            BorderThickness="0,0,0,2" 
                            BorderBrush="{StaticResource ComicYellow}" 
                            Padding="25,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Título de Colección -->
                            <TextBlock x:Name="CollectionTitleText" 
                                       Grid.Row="0" 
                                       Text="Selecciona una Colección" 
                                       FontSize="30" 
                                       FontWeight="Black" 
                                       Foreground="{StaticResource ComicYellow}"
                                       FontFamily="Impact"/>

                            <!-- Búsqueda + Acciones -->
                            <Grid Grid.Row="1" Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Búsqueda -->
                                <Grid Grid.Column="0" Margin="0,0,15,0">
                                    <TextBox x:Name="SearchTextBox" 
                                             Style="{StaticResource ComicSearchBoxStyle}" 
                                             TextChanged="SearchTextBox_TextChanged" 
                                             Text=""/>
                                    <TextBlock Text="🔍 Buscar cómics..." 
                                               IsHitTestVisible="False"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="16"
                                               Padding="16,12"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=SearchTextBox, Path=Text}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- Tag Filter -->
                                <ComboBox x:Name="TagFilterComboBox" 
                                          Grid.Column="1" 
                                          SelectionChanged="TagFilterComboBox_SelectionChanged" 
                                          Width="160" 
                                          Height="48" 
                                          Margin="0,0,15,0"
                                          Background="{StaticResource MediumBg}"
                                          Foreground="{StaticResource TextLight}"
                                          BorderBrush="{StaticResource ComicBlue}"
                                          BorderThickness="2"/>

                                <!-- Botones de Agregar -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Content="+ AGREGAR CÓMICS" 
                                            Style="{StaticResource ComicButtonStyle}" 
                                            Click="AddToCollection_Click" 
                                            Padding="20,10"
                                            Margin="0,0,10,0"/>
                                    <Button Content="📁 CARPETA" 
                                            Style="{StaticResource SecondaryComicButtonStyle}" 
                                            Click="AddFolderToCollection_Click" 
                                            Padding="16,10"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Galería de Cómics -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled" 
                                  Background="{StaticResource DarkBg}"
                                  Padding="15">
                        <ListBox x:Name="FavoritesListBox" 
                                 Background="Transparent"
                                 BorderThickness="0"
                                 AllowDrop="True" 
                                 DragOver="FavoritesListBox_DragOver" 
                                 Drop="FavoritesListBox_Drop">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!-- DYNAMIC COMIC CARD -->
                                    <Border Style="{StaticResource ComicCardStyle}" 
                                            Width="220" 
                                            Height="380"
                                            MouseLeftButtonDown="OpenFavorite_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="280"/>
                                                <!-- Cover -->
                                                <RowDefinition Height="*"/>
                                                <!-- Info -->
                                            </Grid.RowDefinitions>

                                            <!-- Portada del Cómic -->
                                            <Border Grid.Row="0" 
                                                    Background="{StaticResource AccentBg}" 
                                                    CornerRadius="8" 
                                                    ClipToBounds="True"
                                                    BorderThickness="3"
                                                    BorderBrush="{StaticResource ComicYellow}">
                                                <Grid>
                                                    <!-- Imagen de Portada -->
                                                    <Image Source="{Binding ThumbnailImage}" 
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                    
                                                    <!-- Placeholder si no hay portada -->
                                                    <TextBlock Text="📖" 
                                                               FontSize="80" 
                                                               HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextMuted}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>

                                            <!-- Comic Info -->
                                            <StackPanel Grid.Row="1" Margin="8,12,8,8">
                                                <TextBlock Text="{Binding Title}" 
                                                           FontWeight="Bold" 
                                                           FontSize="15" 
                                                           Foreground="{StaticResource TextLight}" 
                                                           TextTrimming="CharacterEllipsis" 
                                                           MaxHeight="40"
                                                           TextWrapping="Wrap"/>
                                                
                                                <TextBlock Text="{Binding Author}" 
                                                           FontSize="12" 
                                                           Foreground="{StaticResource TextMuted}" 
                                                           Margin="0,4,0,0" 
                                                           TextTrimming="CharacterEllipsis"/>

                                                <!-- Rating Stars -->
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <TextBlock Text="★★★★★" 
                                                               FontSize="14" 
                                                               Foreground="{StaticResource ComicYellow}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Menú Contextual -->
                                            <Grid.ContextMenu>
                                                <ContextMenu Background="{StaticResource MediumBg}" 
                                                             Foreground="{StaticResource TextLight}">
                                                    <MenuItem Header="📖 Abrir Cómic" Click="OpenFavorite_Click" FontWeight="Bold"/>
                                                    <MenuItem Header="📁 Mostrar en Carpeta" Click="ShowInFolderFromItem_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="🗑️ Quitar" Click="RemoveFromCollection_Click"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                </Grid>
            </Grid>
        </Grid>
</Window>

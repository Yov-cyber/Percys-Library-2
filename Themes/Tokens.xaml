<?xml version="1.0" encoding="utf-8"?>
<!--
  Percy's Library — Design Tokens (single source of truth, Phase 1).

  Reglas:
  - 3 superficies (Base / Raised / Overlay), 2 niveles de texto, 1 acento.
  - El acento azul (#3B82F6) se reserva para acción primaria y progreso de lectura.
  - Estados (Success / Warning / Danger) se usan SOLO para feedback, nunca decoración.
  - Sin gradientes, sin glow, sin sombras decorativas. Las sombras viven sólo en overlays.
  - Tipografía: Segoe UI Variable. Sin Bangers / Komika / Comic Sans.
  - Pinceles legacy quedan como alias para que las pantallas existentes sigan funcionando
    sin reescribirse aún (eso pasa en Fases 2-4).

  IMPORTANTE: ThemeManager.cs en runtime sobreescribe los *Color y deriva los *Brush.
  Los valores aquí son el FALLBACK estático y deben coincidir con CreateDarkTheme()
  en ThemeManager.cs.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- ============================================================ -->
  <!-- SUPERFICIES                                                  -->
  <!-- ============================================================ -->
  <Color x:Key="Surface.Base">#0E0F12</Color>
  <Color x:Key="Surface.Raised">#16181D</Color>
  <Color x:Key="Surface.Overlay">#1F222A</Color>
  <Color x:Key="Surface.Hover">#262932</Color>
  <Color x:Key="Surface.Selected">#1B2638</Color>

  <!-- TEXTO -->
  <Color x:Key="Text.Primary">#ECEDEE</Color>
  <Color x:Key="Text.Secondary">#9BA1A8</Color>
  <Color x:Key="Text.Disabled">#5C6168</Color>
  <Color x:Key="Text.OnAccent">#FFFFFF</Color>

  <!-- ACENTO (único) -->
  <Color x:Key="Accent">#3B82F6</Color>
  <Color x:Key="Accent.Hover">#4F8EF7</Color>
  <Color x:Key="Accent.Pressed">#2563EB</Color>
  <Color x:Key="Accent.Subtle">#1B2638</Color>

  <!-- BORDES -->
  <Color x:Key="Border.Subtle">#262932</Color>
  <Color x:Key="Border.Strong">#3A3F4A</Color>

  <!-- ESTADOS (sólo feedback, no decoración) -->
  <Color x:Key="Success">#10B981</Color>
  <Color x:Key="Warning">#F59E0B</Color>
  <Color x:Key="Danger">#EF4444</Color>

  <!-- ============================================================ -->
  <!-- COLOR KEYS legacy (los que ThemeManager.cs maneja)           -->
  <!-- Mantener estos nombres por compatibilidad. ThemeManager los  -->
  <!-- sobreescribe en runtime y deriva los *Brush correspondientes. -->
  <!-- ============================================================ -->
  <Color x:Key="WindowBackgroundColor">#0E0F12</Color>
  <Color x:Key="PanelBackgroundColor">#16181D</Color>
  <Color x:Key="HeaderBackgroundColor">#16181D</Color>
  <Color x:Key="InputBackgroundColor">#16181D</Color>
  <Color x:Key="CardBackgroundColor">#16181D</Color>

  <Color x:Key="TextColor">#ECEDEE</Color>
  <Color x:Key="SecondaryTextColor">#9BA1A8</Color>
  <Color x:Key="DisabledTextColor">#5C6168</Color>
  <Color x:Key="HeaderTextColor">#ECEDEE</Color>
  <Color x:Key="MutedTextColor">#9BA1A8</Color>

  <Color x:Key="PrimaryColor">#3B82F6</Color>
  <Color x:Key="PrimaryColorDark">#2563EB</Color>
  <Color x:Key="SecondaryColor">#16181D</Color>
  <Color x:Key="AccentColor">#3B82F6</Color>
  <Color x:Key="ErrorColor">#EF4444</Color>

  <Color x:Key="BorderColor">#262932</Color>
  <Color x:Key="ItemHoverColor">#262932</Color>
  <Color x:Key="ItemSelectedColor">#1B2638</Color>
  <Color x:Key="CurrentPageColor">#1B2638</Color>
  <Color x:Key="CurrentPageBorderColor">#3B82F6</Color>
  <Color x:Key="BookmarkColor">#F59E0B</Color>

  <!-- Color tokens legacy con namespacing tipo "Color.*" -->
  <Color x:Key="Color.Primary.Blue">#3B82F6</Color>
  <Color x:Key="Color.Primary.Red">#EF4444</Color>
  <Color x:Key="Color.Primary.Yellow">#F59E0B</Color>
  <Color x:Key="Color.Primary.Orange">#F59E0B</Color>
  <Color x:Key="Color.Primary.Purple">#3B82F6</Color>
  <Color x:Key="Color.Primary.Green">#10B981</Color>
  <Color x:Key="Color.Neutral.Dark">#0E0F12</Color>
  <Color x:Key="Color.Neutral.Mid">#16181D</Color>
  <Color x:Key="Color.Neutral.Light">#262932</Color>
  <Color x:Key="Color.Neutral.SoftWhite">#ECEDEE</Color>
  <Color x:Key="Color.Neutral.OffWhite">#9BA1A8</Color>
  <Color x:Key="Color.Background.Deep">#0E0F12</Color>
  <Color x:Key="Color.Background.Card">#16181D</Color>
  <Color x:Key="Color.Background.Panel">#16181D</Color>

  <!-- BgColor / CardBgColor / DarkBg / MediumBg legacy -->
  <Color x:Key="BgColor">#0E0F12</Color>
  <Color x:Key="CardBgColor">#16181D</Color>
  <Color x:Key="DarkBg">#0E0F12</Color>
  <Color x:Key="MediumBg">#16181D</Color>
  <Color x:Key="FooterBackground">#16181D</Color>
  <Color x:Key="HeaderBackground">#16181D</Color>
  <Color x:Key="IconAccentColor">#3B82F6</Color>
  <Color x:Key="CS_BackgroundColor">#0E0F12</Color>

  <!-- ============================================================ -->
  <!-- BRUSHES — semánticos                                         -->
  <!-- ============================================================ -->
  <SolidColorBrush x:Key="Surface.Base.Brush" Color="{StaticResource Surface.Base}"/>
  <SolidColorBrush x:Key="Surface.Raised.Brush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="Surface.Overlay.Brush" Color="{StaticResource Surface.Overlay}"/>
  <SolidColorBrush x:Key="Surface.Hover.Brush" Color="{StaticResource Surface.Hover}"/>
  <SolidColorBrush x:Key="Surface.Selected.Brush" Color="{StaticResource Surface.Selected}"/>

  <SolidColorBrush x:Key="Text.Primary.Brush" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="Text.Secondary.Brush" Color="{StaticResource Text.Secondary}"/>
  <SolidColorBrush x:Key="Text.Disabled.Brush" Color="{StaticResource Text.Disabled}"/>
  <SolidColorBrush x:Key="Text.OnAccent.Brush" Color="{StaticResource Text.OnAccent}"/>

  <SolidColorBrush x:Key="Accent.Brush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="Accent.Hover.Brush" Color="{StaticResource Accent.Hover}"/>
  <SolidColorBrush x:Key="Accent.Pressed.Brush" Color="{StaticResource Accent.Pressed}"/>
  <SolidColorBrush x:Key="Accent.Subtle.Brush" Color="{StaticResource Accent.Subtle}"/>

  <SolidColorBrush x:Key="Border.Subtle.Brush" Color="{StaticResource Border.Subtle}"/>
  <SolidColorBrush x:Key="Border.Strong.Brush" Color="{StaticResource Border.Strong}"/>

  <SolidColorBrush x:Key="Success.Brush" Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="Warning.Brush" Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="Danger.Brush" Color="{StaticResource Danger}"/>

  <!-- ============================================================ -->
  <!-- BRUSHES legacy — aliases para compilación.                   -->
  <!-- Algunos los sobreescribe ThemeManager.cs en runtime          -->
  <!-- (los *Brush derivados de un *Color con el mismo prefijo).    -->
  <!-- ============================================================ -->

  <!-- Superficies / fondos -->
  <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource Surface.Base}"/>
  <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Surface.Base}"/>
  <SolidColorBrush x:Key="DocumentBackgroundBrush" Color="{StaticResource Surface.Base}"/>
  <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="ItemHoverBrush" Color="{StaticResource Surface.Hover}"/>
  <SolidColorBrush x:Key="ItemSelectedBrush" Color="{StaticResource Surface.Selected}"/>
  <SolidColorBrush x:Key="CurrentPageBrush" Color="{StaticResource Surface.Selected}"/>
  <SolidColorBrush x:Key="ComicBackgroundBrush" Color="{StaticResource Surface.Base}"/>
  <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="PlaceholderImageBrush" Color="{StaticResource Surface.Overlay}"/>
  <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#A6000000"/>

  <!-- Texto -->
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="ButtonForegroundBrush" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="HeaderTextColorBrush" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource Text.Secondary}"/>
  <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource Text.Secondary}"/>
  <SolidColorBrush x:Key="TextLight" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="TextMuted" Color="{StaticResource Text.Secondary}"/>
  <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource Text.Disabled}"/>
  <SolidColorBrush x:Key="IndicatorText" Color="{StaticResource Text.Secondary}"/>

  <!-- Acento -->
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="AccentForegroundBrush" Color="{StaticResource Text.OnAccent}"/>
  <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource Accent.Hover}"/>
  <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource Accent.Pressed}"/>
  <SolidColorBrush x:Key="AccentLowBrush" Color="#1A3B82F6"/>
  <SolidColorBrush x:Key="AccentBg" Color="{StaticResource Accent.Subtle}"/>
  <SolidColorBrush x:Key="Accent1Brush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent.Pressed}"/>
  <SolidColorBrush x:Key="IconAccentBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="PrimaryBrushDark" Color="{StaticResource Accent.Pressed}"/>
  <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource Surface.Raised}"/>

  <!-- Bordes -->
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border.Subtle}"/>
  <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="CurrentPageBorderBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="IndicatorBorder" Color="{StaticResource Border.Subtle}"/>
  <SolidColorBrush x:Key="ModernCardBorder" Color="{StaticResource Border.Subtle}"/>

  <!-- Estados / progreso / bookmark -->
  <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Danger}"/>
  <SolidColorBrush x:Key="ErrorHoverBrush" Color="{StaticResource Danger}"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="BookmarkBrush" Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="DisabledBrush" Color="#406B7280"/>

  <!-- ComboBox legacy -->
  <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource Border.Subtle}"/>
  <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="ComboBoxPopupBackgroundBrush" Color="{StaticResource Surface.Overlay}"/>
  <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="{StaticResource Surface.Hover}"/>
  <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="ComboBoxItemSelectedTextBrush" Color="{StaticResource Text.OnAccent}"/>

  <!-- Recientes / Home (HomeView referencia explícitamente estos) -->
  <SolidColorBrush x:Key="RecentsCardBg" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="RecentsCardBorder" Color="{StaticResource Border.Subtle}"/>
  <SolidColorBrush x:Key="RecentsAccent" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="RecentsAccentDark" Color="{StaticResource Accent.Pressed}"/>
  <SolidColorBrush x:Key="RecentsDanger" Color="{StaticResource Danger}"/>
  <SolidColorBrush x:Key="RecentsDangerDark" Color="{StaticResource Danger}"/>
  <SolidColorBrush x:Key="RecentsText" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="RecentsSubtle" Color="{StaticResource Text.Secondary}"/>
  <SolidColorBrush x:Key="RecentsPanelBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="RecentsPanelBorderBrush" Color="{StaticResource Border.Subtle}"/>

  <!-- Cómic legacy: la estética cómic muere aquí. Quedan como aliases para compilar. -->
  <SolidColorBrush x:Key="ComicBlue" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="ComicGreen" Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="ComicYellow" Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="ComicOrange" Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="ComicAccentBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="ComicBorderBrush" Color="{StaticResource Border.Subtle}"/>
  <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="ComicHalftoneBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="HalftonePattern" Color="Transparent"/>
  <SolidColorBrush x:Key="StarburstBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="SpeechBubbleBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="ComicProgressFill" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="ComicProgressStripes" Color="Transparent"/>
  <SolidColorBrush x:Key="ComicReaderTopBarGradient" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="HoverGlow" Color="Transparent"/>

  <!-- Reading-stats legacy (RS_*) -->
  <SolidColorBrush x:Key="RS_AppBackgroundBrush" Color="{StaticResource Surface.Base}"/>
  <SolidColorBrush x:Key="RS_SurfaceBrush" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="RS_SurfaceElevatedBrush" Color="{StaticResource Surface.Overlay}"/>
  <SolidColorBrush x:Key="RS_TextOnDarkBrush" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="RS_TextMutedBrush" Color="{StaticResource Text.Secondary}"/>
  <SolidColorBrush x:Key="RS_AccentBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="RS_SuccessBrush" Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="RS_WarningBrush" Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="RS_DangerBrush" Color="{StaticResource Danger}"/>
  <SolidColorBrush x:Key="RS_ComicGreen" Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="RS_ComicRed" Color="{StaticResource Danger}"/>
  <SolidColorBrush x:Key="RS_ComicYellow" Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="RS_ComicPanelGradient" Color="{StaticResource Surface.Raised}"/>

  <!-- Brush.* legacy -->
  <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="Brush.Primary.Accent" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Danger}"/>
  <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="Brush.Window" Color="{StaticResource Surface.Base}"/>
  <SolidColorBrush x:Key="Brush.Card" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="Brush.Panel" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Text.Secondary}"/>
  <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Border.Subtle}"/>
  <SolidColorBrush x:Key="Brush.Header.Gradient" Color="{StaticResource Surface.Raised}"/>

  <!-- Collections (CS_*) legacy: Phase 1 los neutraliza al sistema oscuro -->
  <SolidColorBrush x:Key="CS_Background" Color="{StaticResource Surface.Base}"/>
  <SolidColorBrush x:Key="CS_CardBackground" Color="{StaticResource Surface.Raised}"/>
  <SolidColorBrush x:Key="CS_TextPrimary" Color="{StaticResource Text.Primary}"/>
  <SolidColorBrush x:Key="CS_TextSecondary" Color="{StaticResource Text.Secondary}"/>
  <SolidColorBrush x:Key="CS_ActionAccent" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="PreviewAccentBrush" Color="{StaticResource Accent}"/>

  <!-- ============================================================ -->
  <!-- TIPOGRAFÍA                                                    -->
  <!-- Una sola familia. Todos los aliases (incluso ComicFont,      -->
  <!-- ComicTitleFont, BodyFont, DisplayFont) apuntan al mismo set. -->
  <!-- ============================================================ -->
  <FontFamily x:Key="AppFontFamily">Segoe UI Variable, Segoe UI, Arial</FontFamily>
  <FontFamily x:Key="AppFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>
  <FontFamily x:Key="ComicFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>
  <FontFamily x:Key="ComicTitleFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>
  <FontFamily x:Key="DisplayFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>
  <FontFamily x:Key="HeaderFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>
  <FontFamily x:Key="BodyFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>
  <FontFamily x:Key="UiFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>

  <!-- ============================================================ -->
  <!-- ESCALAS                                                      -->
  <!-- ============================================================ -->
  <sys:Double x:Key="FontSize.Caption">12</sys:Double>
  <sys:Double x:Key="FontSize.Body">14</sys:Double>
  <sys:Double x:Key="FontSize.Title">18</sys:Double>
  <sys:Double x:Key="FontSize.Display">24</sys:Double>
  <sys:Double x:Key="BaseFontSize">14</sys:Double>
  <sys:Double x:Key="HeadingFontSize">18</sys:Double>

  <sys:Double x:Key="Spacing.XS">4</sys:Double>
  <sys:Double x:Key="Spacing.S">8</sys:Double>
  <sys:Double x:Key="Spacing.M">12</sys:Double>
  <sys:Double x:Key="Spacing.L">16</sys:Double>
  <sys:Double x:Key="Spacing.XL">24</sys:Double>
  <sys:Double x:Key="Spacing.XXL">32</sys:Double>

  <CornerRadius x:Key="Radius.None">0</CornerRadius>
  <CornerRadius x:Key="Radius.S">4</CornerRadius>
  <CornerRadius x:Key="Radius.M">6</CornerRadius>
  <CornerRadius x:Key="Radius.L">8</CornerRadius>
  <CornerRadius x:Key="Radius.XL">12</CornerRadius>

  <!-- Reading-stats numérico legacy -->
  <sys:Double x:Key="RS_StatValueSize">22</sys:Double>
  <sys:Double x:Key="RS_StatLabelSize">12</sys:Double>
  <CornerRadius x:Key="RS_CardCorner">8</CornerRadius>

  <!-- ============================================================ -->
  <!-- EFECTOS                                                      -->
  <!-- Sin sombras decorativas. CardShadow y demás se neutralizan.  -->
  <!-- ============================================================ -->
  <DropShadowEffect x:Key="CardShadow" Color="Transparent" BlurRadius="0" Opacity="0" ShadowDepth="0"/>

</ResourceDictionary>

<Window x:Class="ComicReader.Views.StatisticsWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:ComicReader.Views.Controls"
	xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
	xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
		Title="📊 Estadísticas de Lectura - Comic Style!" Height="640" Width="1024"
		WindowStartupLocation="CenterOwner"
		Background="{DynamicResource BackgroundBrush}">

	<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
		<Grid Margin="18">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- 💥 Header tipo cómic con efecto POW! -->
		<Border Background="#1A2332" CornerRadius="12" Padding="12,8" Margin="0,0,0,12" BorderBrush="#00D9FF" BorderThickness="3">
			<Border.Effect>
				<DropShadowEffect Color="#00D9FF" BlurRadius="20" Opacity="0.4" ShadowDepth="0"/>
			</Border.Effect>
			<TextBlock Text="📊 ESTADÍSTICAS DE LECTURA 💥" FontSize="32" FontWeight="Black" 
					   Foreground="#FFE44D" HorizontalAlignment="Center" TextAlignment="Center">
				<TextBlock.Effect>
					<DropShadowEffect Color="#FF1744" BlurRadius="8" Opacity="0.8" ShadowDepth="2"/>
				</TextBlock.Effect>
			</TextBlock>
		</Border>

		<!-- Main content -->
		<Grid Grid.Row="1" Margin="0,12,0,12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="3*" />
				<ColumnDefinition Width="2*" />
			</Grid.ColumnDefinitions>

			<!-- Left column: resumen y progreso -->
			<StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,12,0">
				<!-- Resumen general: tarjetas en un panel con binding y drag & drop -->
				<ItemsControl ItemsSource="{Binding Stats}" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True" HorizontalAlignment="Center">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<!-- allow variable height cards so labels can wrap naturally -->
							<WrapPanel IsItemsHost="True" Orientation="Horizontal" ItemWidth="220" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<controls:StatCard Label="{Binding Label}" Value="{Binding Value}" Margin="6" />
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<!-- Progreso Actual con estilo viñeta -->
				<Border Style="{StaticResource RS_StatCardStyle}" Padding="12" Margin="0,16,0,12">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>
						<TextBlock Text="⚡ PROGRESO ACTUAL" Foreground="#FFE44D" FontWeight="Black" FontSize="16" Margin="4">
							<TextBlock.Effect>
								<DropShadowEffect Color="#000000" BlurRadius="4" Opacity="0.8" ShadowDepth="2"/>
							</TextBlock.Effect>
						</TextBlock>

						<Grid Grid.Row="1">
							<!-- Scrollable progress list -->
							<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="220">
								<ItemsControl ItemsSource="{Binding ProgressList}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<controls:ProgressComicItem Title="{Binding Title}" Percentage="{Binding Percentage}" 
																	   PagesText="{Binding PagesText}" ThumbnailPath="{Binding ThumbnailPath}" 
																	   AccessibilityHelp="{Binding AccessibilityHelp}" Margin="0,6" />
										</DataTemplate>
									</ItemsControl.ItemTemplate>
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<StackPanel />
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
								</ItemsControl>
							</ScrollViewer>

							<!-- Placeholder when no progress items exist -->
							<TextBlock Text="💤 No hay progreso reciente" Foreground="{DynamicResource SecondaryTextBrush}" 
									   Opacity="0.75" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontStyle="Italic">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Setter Property="Visibility" Value="Collapsed" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding ProgressList.Count}" Value="0">
												<Setter Property="Visibility" Value="Visible" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
						</Grid>
					</Grid>
				</Border>

				<!-- Chart con estilo panel de cómic -->
				<Border Style="{StaticResource RS_StatCardStyle}" Padding="12" Margin="0,0,0,12">
					<StackPanel>
						<TextBlock Text="📈 LECTURAS POR DÍA" Foreground="#00E5FF" FontWeight="Black" FontSize="16" Margin="4">
							<TextBlock.Effect>
								<DropShadowEffect Color="#000000" BlurRadius="4" Opacity="0.8" ShadowDepth="2"/>
							</TextBlock.Effect>
						</TextBlock>
						<Grid Height="160">
							<lvc:CartesianChart Series="{Binding Series}" Background="Transparent" />
						</Grid>
					</StackPanel>
				</Border>
			</StackPanel>

			<!-- Right column: preferencias y sesiones -->
			<StackPanel Grid.Column="1" Orientation="Vertical">
				<!-- Panel de favoritos estilo cómic -->
				<Border Style="{StaticResource RS_StatCardStyle}" Padding="14" Margin="0,0,0,16">
					<StackPanel>
						<TextBlock Text="⭐ FAVORITOS" Foreground="#B388FF" FontWeight="Black" FontSize="16" Margin="0,0,0,10">
							<TextBlock.Effect>
								<DropShadowEffect Color="#000000" BlurRadius="4" Opacity="0.8" ShadowDepth="2"/>
							</TextBlock.Effect>
						</TextBlock>
						<StackPanel Margin="8,0,0,0">
							<TextBlock Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" 
									   Text="{Binding FavoriteGenre, StringFormat='🎭 Género: {0}'}" Margin="0,4" />
							<TextBlock Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" 
									   Text="{Binding FavoriteDay, StringFormat='📅 Día: {0}'}" Margin="0,4" />
							<TextBlock Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" 
									   Text="{Binding PreferredFormat, StringFormat='📚 Formato: {0}'}" Margin="0,4" />
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- Sesiones con efecto viñeta -->
				<Border Style="{StaticResource RS_StatCardStyle}" Padding="12">
					<StackPanel>
						<TextBlock Text="🕐 SESIONES DE HOY" Foreground="#00FFA3" FontWeight="Black" FontSize="16" Margin="0,0,0,10">
							<TextBlock.Effect>
								<DropShadowEffect Color="#000000" BlurRadius="4" Opacity="0.8" ShadowDepth="2"/>
							</TextBlock.Effect>
						</TextBlock>
						<ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280">
							<ItemsControl ItemsSource="{Binding TodaySessions}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
					<Border Background="#0F3460" Padding="8" Margin="0,6" CornerRadius="6" Focusable="True"
						AutomationProperties.Name="{Binding Title}" AutomationProperties.HelpText="{Binding HelpText}"
						MouseLeftButtonDown="SessionItem_MouseLeftButtonDown" KeyDown="SessionItem_KeyDown"
						BorderBrush="#00D9FF" BorderThickness="1">
											<Border.Style>
												<Style TargetType="Border">
													<Setter Property="Background" Value="#0F3460" />
													<Setter Property="SnapsToDevicePixels" Value="True" />
													<Style.Triggers>
														<Trigger Property="IsMouseOver" Value="True">
															<Setter Property="Background" Value="#1A4A7E" />
															<Setter Property="BorderBrush" Value="#FFD700" />
														</Trigger>
														<Trigger Property="IsKeyboardFocusWithin" Value="True">
															<Setter Property="Background" Value="#1A4A7E" />
															<Setter Property="BorderBrush" Value="#FFD700" />
														</Trigger>
													</Style.Triggers>
												</Style>
											</Border.Style>
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="60" />
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="Auto" />
												</Grid.ColumnDefinitions>
												<TextBlock Text="{Binding StartText}" Foreground="#00E5FF" FontWeight="Bold" FontSize="13" VerticalAlignment="Top" />
												<StackPanel Grid.Column="1" Orientation="Vertical" Margin="10,0,0,0">
													<TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextBrush}" FontWeight="Bold" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" />
													<TextBlock Text="{Binding PagesText}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" />
												</StackPanel>
												<TextBlock Grid.Column="2" Text="{Binding DurationText}" Foreground="#FFE44D" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0" />
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</ScrollViewer>
					</StackPanel>
				</Border>
			</StackPanel>
		</Grid>

		<!-- 🎯 Footer: acciones con botones estilo cómic -->
		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
			<Button Content="💾 EXPORTAR" Background="#00E676" Foreground="#000000" FontWeight="Black" 
					Padding="16,8" Margin="8" Click="ExportButton_Click" BorderBrush="#000000" BorderThickness="2">
				<Button.Effect>
					<DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.6" ShadowDepth="3"/>
				</Button.Effect>
			</Button>
			<Button Content="🗑️ RESETEAR" Background="#E94560" Foreground="#FFFFFF" FontWeight="Black" 
					Padding="16,8" Margin="8" Click="ResetButton_Click" BorderBrush="#000000" BorderThickness="2">
				<Button.Effect>
					<DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.6" ShadowDepth="3"/>
				</Button.Effect>
			</Button>
			<Button Content="✖️ CERRAR" Background="#16213E" Foreground="#FFFFFF" FontWeight="Bold" 
					Padding="16,8" Margin="8" Click="CloseButton_Click" BorderBrush="#00D9FF" BorderThickness="2">
				<Button.Effect>
					<DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.6" ShadowDepth="3"/>
				</Button.Effect>
			</Button>
		</StackPanel>
		</Grid>
	</ScrollViewer>
</Window>


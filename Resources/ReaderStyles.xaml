<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Estilos ligeros para la barra del lector y el toggle -->
  <!-- Brushes y estilo cómic para la barra del lector -->
  <LinearGradientBrush x:Key="ComicReaderTopBarGradient" StartPoint="0,0" EndPoint="1,0">
    <GradientStop Color="{DynamicResource PanelBackgroundColor}" Offset="0"/>
    <GradientStop Color="{DynamicResource AccentColor}" Offset="0.4"/>
    <GradientStop Color="{DynamicResource PrimaryColor}" Offset="1"/>
  </LinearGradientBrush>

  <!-- Patrón de semitono suave para overlays -->
  <DrawingBrush x:Key="ComicHalftoneBrush" ViewportUnits="Absolute" TileMode="Tile" Viewport="0,0,8,8" Stretch="None" Opacity="0.12">
    <DrawingBrush.Drawing>
      <GeometryDrawing Brush="White">
        <GeometryDrawing.Geometry>
          <GeometryGroup>
            <GeometryGroup.Children>
              <EllipseGeometry Center="2,2" RadiusX="1" RadiusY="1"/>
              <EllipseGeometry Center="6,6" RadiusX="1" RadiusY="1"/>
            </GeometryGroup.Children>
          </GeometryGroup>
        </GeometryDrawing.Geometry>
      </GeometryDrawing>
    </DrawingBrush.Drawing>
  </DrawingBrush>

  <Style x:Key="ReaderTopBarStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource ComicReaderTopBarGradient}"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="CornerRadius" Value="14"/>
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="3"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Visibility" Value="Collapsed"/>
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect Color="#000000" BlurRadius="16" Opacity="0.22" ShadowDepth="3"/>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsReaderViewActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
        <Setter Property="Visibility" Value="Visible"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding IsHomeViewActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
        <Setter Property="Visibility" Value="Collapsed"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding IsSettingsViewActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
        <Setter Property="Visibility" Value="Collapsed"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="ReaderToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource ComicButtonStyle}">
    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    <Setter Property="Margin" Value="6,0"/>
    <Setter Property="Padding" Value="6,4"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Opacity" Value="0.95"/>
              <Setter Property="RenderTransform">
                <Setter.Value>
                  <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Botón de icono estilo cómic para la barra del lector -->
  <Style x:Key="ReaderIconButtonStyle" TargetType="Button">
    <Setter Property="Width" Value="36"/>
    <Setter Property="Height" Value="36"/>
    <Setter Property="Padding" Value="6"/>
    <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="10">
            <Border.Effect>
              <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.18"/>
            </Border.Effect>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource OverlayBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentLowBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Slider estilo cómic para navegación de páginas -->
  <Style x:Key="ReaderSliderStyle" TargetType="Slider">
    <Setter Property="Height" Value="16"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Track x:Name="PART_Track" Grid.Column="1">
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="Slider.DecreaseLarge" Opacity="0">
                  <RepeatButton.Template>
                    <ControlTemplate TargetType="RepeatButton">
                      <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" Height="6"/>
                    </ControlTemplate>
                  </RepeatButton.Template>
                </RepeatButton>
              </Track.DecreaseRepeatButton>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="Slider.IncreaseLarge" Opacity="0">
                  <RepeatButton.Template>
                    <ControlTemplate TargetType="RepeatButton">
                      <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" Height="6"/>
                    </ControlTemplate>
                  </RepeatButton.Template>
                </RepeatButton>
              </Track.IncreaseRepeatButton>
              <Track.Thumb>
                <!-- Thumb funcional pero visualmente oculto: mantiene arrastre sin mostrar el gran punto azul -->
                <Thumb Width="14" Height="14" Cursor="Hand" Focusable="False" FocusVisualStyle="{x:Null}">
                  <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                      <!-- Usamos un borde transparente para mantener el área de interacción sin el color azul -->
                      <Border Width="14" Height="14" CornerRadius="7" Background="Transparent" BorderBrush="Transparent" BorderThickness="0"/>
                    </ControlTemplate>
                  </Thumb.Template>
                </Thumb>
              </Track.Thumb>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Modern ProgressBar style: rounded, subtle gradient -->
  <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
    <Setter Property="Height" Value="14"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="7" Padding="2">
            <Grid ClipToBounds="True">
              <Rectangle x:Name="PART_Indicator" Fill="{TemplateBinding Foreground}" RadiusX="6" RadiusY="6" HorizontalAlignment="Left"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsIndeterminate" Value="True">
              <Setter TargetName="PART_Indicator" Property="Width" Value="40"/>
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
              <Setter TargetName="PART_Indicator" Property="Width" Value="0"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ProgressBar cómic para el lector: degradado + stripes suaves -->
  <LinearGradientBrush x:Key="ComicProgressFill" StartPoint="0,0" EndPoint="1,0">
    <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
    <GradientStop Color="{DynamicResource PrimaryColor}" Offset="1"/>
  </LinearGradientBrush>
  <DrawingBrush x:Key="ComicProgressStripes" ViewportUnits="Absolute" Viewport="0,0,12,12" TileMode="Tile" Stretch="None" Opacity="0.18">
    <DrawingBrush.Drawing>
      <GeometryDrawing Brush="White">
        <GeometryDrawing.Geometry>
          <GeometryGroup>
            <GeometryGroup.Children>
              <RectangleGeometry Rect="0,6,12,2"/>
              <RectangleGeometry Rect="6,0,2,12"/>
            </GeometryGroup.Children>
          </GeometryGroup>
        </GeometryDrawing.Geometry>
      </GeometryDrawing>
    </DrawingBrush.Drawing>
  </DrawingBrush>
  <Style x:Key="ReaderProgressBarStyle" TargetType="ProgressBar">
    <Setter Property="Height" Value="12"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ComicProgressFill}"/>
    <Setter Property="Template">
      <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
          <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="8" Padding="2">
            <Grid ClipToBounds="True">
              <!-- PART_Indicator como contenedor del área rellena -->
              <Grid x:Name="PART_Indicator" HorizontalAlignment="Left" VerticalAlignment="Stretch">
                <!-- relleno de la barra (se escala según Value) -->
                <Rectangle Fill="{TemplateBinding Foreground}" RadiusX="6" RadiusY="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                <!-- stripes sólo dentro del área rellena -->
                <Rectangle Fill="{StaticResource ComicProgressStripes}" RadiusX="6" RadiusY="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                <!-- indicador circular dentro del relleno -->
                <Ellipse x:Name="PART_ProgressThumb" Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Center" Fill="{DynamicResource AccentBrush}" Stroke="{DynamicResource PanelBackgroundBrush}" StrokeThickness="2" />
              </Grid>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsIndeterminate" Value="True">
              <Setter TargetName="PART_Indicator" Property="Width" Value="40"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Dialog button style for small dialogs -->
  <Style x:Key="ModernDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource ReaderToggleButtonStyle}">
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="Height" Value="28"/>
    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Opacity" Value="0.95"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter Property="Opacity" Value="0.85"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>

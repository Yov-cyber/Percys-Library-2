<Application x:Class="ComicReader.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ComicReader.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
            >
    <Application.Resources>
        <ResourceDictionary>
            <!-- Incluir estilos base -->
            <ResourceDictionary.MergedDictionaries>
                <!-- Bootstrap: estilos mínimos cargados primero para evitar referencias faltantes -->
                <ResourceDictionary Source="Themes/Bootstrap.xaml" />
                <!-- Modern theme added first so tokens can be overridden by other theme files if needed -->
                <ResourceDictionary Source="Themes/Modern.xaml"/>
                <ResourceDictionary Source="Themes/ThemeTokens.xaml"/>
                <ResourceDictionary Source="Themes/BaseStyles.xaml"/>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="Themes/CardStyles.xaml"/>
                <ResourceDictionary Source="Resources/ReaderStyles.xaml"/>
                <!-- Comic controls & styles (fallbacks and comic-themed controls) -->
                <ResourceDictionary Source="Styles/Controls.Comic.xaml" />
                <!-- Redesign overrides and new components -->
                <ResourceDictionary Source="Styles/ComicRedesignControls.xaml" />
                <ResourceDictionary Source="Styles/ComicRedesignTheme.xaml" />
                <ResourceDictionary Source="Themes/ReadingStatsResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Global rendering and UI tokens -->
            <sys:Boolean x:Key="UseBitmapScalingModeHighQuality">True</sys:Boolean>
            <!-- Default app font (uses Segoe UI Variable if available) -->
            <FontFamily x:Key="AppFontFamily">Segoe UI Variable, Segoe UI, Arial</FontFamily>
            <!-- Application-level RenderOptions -->
            <Style TargetType="Window">
                <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            </Style>
            <!-- Hint to use high-quality bitmap scaling in controls that respect it -->
            <sys:Boolean x:Key="PreferHighQualityScaling">True</sys:Boolean>
            
            <!-- Convertidores -->
            <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
            <converters:NullToVisibleConverter x:Key="NullToVisibleConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:IsComicViewVisibleConverter x:Key="IsComicViewVisibleConverter"/>
            <converters:StringToBrushConverter x:Key="StringToBrushConverter" />
            
            <!-- Paleta ahora proviene de ThemeTokens.xaml -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
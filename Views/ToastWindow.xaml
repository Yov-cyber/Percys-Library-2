<Window x:Class="ComicReader.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True"
        Width="360" Height="84" ResizeMode="NoResize" Opacity="0">

    <!-- Comic-style toast: speech-bubble look, bold rounded font, icon, and entrance animation target -->
    <Border x:Name="RootBorder" Background="#FF1B1F23" CornerRadius="12" Padding="12" Margin="8" Opacity="0.98" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="6" Opacity="0.7" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- icon / speech bubble -->
            <Border Grid.Column="0" Width="36" Height="36" Background="#FFF3C969" CornerRadius="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="IconText" Text="💬" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,8,0">
                <TextBlock x:Name="MessageText" Foreground="#FF0A0A0A" TextWrapping="Wrap" FontSize="14" FontFamily="Comic Sans MS, Arial" FontWeight="Bold" />
                <TextBlock x:Name="SubText" Foreground="#AA0A0A0A" FontSize="11" Visibility="Collapsed" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                <Button x:Name="ActionButton" Content="Deshacer" Visibility="Collapsed" Margin="0,0,0,0" Click="ActionButton_Click" AutomationProperties.Name="Acción del toast"
                        Padding="8,4" Background="#FF2BC67D" Foreground="White" BorderBrush="#FF1A7A4C" BorderThickness="1" FontWeight="SemiBold" Cursor="Hand"/>
            </StackPanel>

            <!-- tiny progress indicator under the content -->
            <Border Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="6" Margin="0,8,0,0" Background="#55FFFFFF" CornerRadius="3">
                <Rectangle x:Name="ProgressFill" Fill="#FF6EE7B7" HorizontalAlignment="Left" RadiusX="3" RadiusY="3" Width="0" />
            </Border>
        </Grid>
    </Border>
</Window>

<Window x:Class="ComicReader.Views.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editor de atajos" Height="420" Width="680" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Editor de atajos" FontSize="18" FontWeight="Bold" />
        <TextBlock Grid.Row="0" Margin="0,28,0,8" Foreground="#666" Text="Pulsa 'Grabar' en una fila y luego la combinación de teclado que desees. Presiona Esc para cancelar."/>

        <ListView x:Name="ListShortcuts" Grid.Row="1" Margin="0,8,0,8" ItemsSource="{Binding Shortcuts}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Acción" Width="260" DisplayMemberBinding="{Binding Description}" />
                    <GridViewColumn Header="Atajo" Width="200" DisplayMemberBinding="{Binding Gesture}" />
                    <GridViewColumn Header="Acciones" Width="160">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Grabar" Margin="0,0,6,0" Padding="6,2" Click="Record_Click" Tag="{Binding}" />
                                    <Button Content="Restablecer" Padding="6,2" Click="Reset_Click" Tag="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Restaurar por defecto" Click="RestoreDefaults_Click" Margin="0,0,8,0" Padding="10,6" />
            <Button Content="Guardar" Click="Save_Click" Padding="12,6" />
        </StackPanel>
    </Grid>
</Window>

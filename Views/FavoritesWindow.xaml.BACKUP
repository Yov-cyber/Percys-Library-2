<Window x:Class="ComicReader.Views.FavoritesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Favoritos y Colecciones" 
        Width="1000" Height="700"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8FAFC">

    <Window.Resources>
        <!-- Estilos Reutilizables -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
        <!-- Chip (tag) style -->
        <Style x:Key="TagChip" TargetType="Border">
            <Setter Property="Background" Value="#FFF1F5F9"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- Card shadow effect (light) -->
        <DropShadowEffect x:Key="CardShadow" Color="#22000000" BlurRadius="12" ShadowDepth="2"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF6366F1" Padding="25,20">
            <StackPanel>
                <TextBlock Text="⭐ FAVORITOS Y COLECCIONES" 
                           FontSize="28" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Organiza y gestiona tus cómics favoritos en colecciones personalizadas" 
                           FontSize="14" Foreground="White" 
                           HorizontalAlignment="Center" Margin="0,5,0,0" Opacity="0.9"/>
            </StackPanel>
        </Border>

        <!-- Contenido Principal -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel Izquierdo - Colecciones -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="📚 COLECCIONES" FontSize="18" FontWeight="Bold" 
                               Foreground="#FF374151" Margin="0,0,0,15"/>
                    
            <Button Style="{StaticResource ModernButtonStyle}"
                Background="#FF10B981" Foreground="White"
                Click="CreateCollection_Click"
                AutomationProperties.Name="Nueva colección">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Nueva Colección"/>
                        </StackPanel>
                    </Button>

            <Button Style="{StaticResource ModernButtonStyle}"
                Background="#FF3B82F6" Foreground="White"
                Click="RenameCollection_Click"
                AutomationProperties.Name="Renombrar colección">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Renombrar"/>
                        </StackPanel>
                    </Button>

            <Button Style="{StaticResource ModernButtonStyle}"
                Background="#FF8B5CF6" Foreground="White"
                Click="DuplicateCollection_Click"
                AutomationProperties.Name="Duplicar colección">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Duplicar"/>
                        </StackPanel>
                    </Button>

            <Button Style="{StaticResource ModernButtonStyle}"
                Background="#FFEF4444" Foreground="White"
                Click="DeleteCollection_Click"
                AutomationProperties.Name="Eliminar colección">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Eliminar Colección"/>
                        </StackPanel>
                    </Button>

                    <ListBox Name="CollectionsListBox" BorderThickness="0" Background="Transparent"
                             SelectionChanged="CollectionsListBox_SelectionChanged" Margin="0,10,0,0"
                             AutomationProperties.Name="Lista de colecciones">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFF3F4F6" CornerRadius="8" Padding="12" Margin="0,2">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Renombrar" Click="RenameCollection_Click"/>
                                            <MenuItem Header="Duplicar" Click="DuplicateCollection_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Eliminar" Click="DeleteCollection_Click"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="14" Height="14" CornerRadius="7" Margin="0,2,10,0"
                                                Background="{Binding Color}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{Binding ItemCount, StringFormat='{}{0} cómics'}" 
                                                       Foreground="#FF6B7280" FontSize="12"/>
                                            <TextBlock Text="{Binding Description}" 
                                                       Foreground="#FF9CA3AF" FontSize="11" 
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Panel Derecho - Contenido de Colección -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,10,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header: título + toolbar (búsqueda + filtros) -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <TextBlock Name="CollectionTitleText" Text="Selecciona una colección"
                                       FontSize="20" FontWeight="Bold" Foreground="#FF374151" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                       <TextBox Name="SearchTextBox" Width="300" Padding="10" FontSize="14"
                              BorderBrush="#FFD1D5DB" BorderThickness="1" VerticalAlignment="Center"
                              TextChanged="SearchTextBox_TextChanged" Margin="0,0,8,0"
                              AutomationProperties.Name="Buscar favoritos">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="White" BorderBrush="#FFD1D5DB"
                                                            BorderThickness="1" CornerRadius="6">
                                                        <ScrollViewer x:Name="PART_ContentHost" Margin="10"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <ComboBox Name="TagFilterComboBox" Width="160" Margin="6,0,6,0" VerticalAlignment="Center"
                                      SelectionChanged="TagFilterComboBox_SelectionChanged" IsEditable="False"
                                      AutomationProperties.Name="Filtro de etiquetas"/>

                            <Button Style="{StaticResource ModernButtonStyle}" Background="#FF3B82F6" Foreground="White" Click="AddToCollection_Click" AutomationProperties.Name="Agregar a colección">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="📖"/> <TextBlock Text="Agregar" Margin="6,0,0,0"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource ModernButtonStyle}" Background="#FFEF4444" Foreground="White" Click="RemoveSelected_Click" Margin="6,0,0,0" AutomationProperties.Name="Quitar selección">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="🗑️"/> <TextBlock Text="Quitar" Margin="6,0,0,0"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <!-- Main: grid con lista (izq) y vista previa (derecha) -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <!-- Lista principal -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <!-- Favorites list -->
                            <ListBox Name="FavoritesListBox" BorderThickness="0" Background="Transparent"
                                     SelectionMode="Extended" AllowDrop="True"
                                     DragOver="FavoritesListBox_DragOver" Drop="FavoritesListBox_Drop"
                                     AutomationProperties.Name="Lista de favoritos">
                            <!-- Use WrapPanel to create responsive card layout -->
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" Orientation="Horizontal" ItemWidth="300" ItemHeight="140"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFFFFFF" CornerRadius="10" Padding="12" Margin="8"
                                            BorderBrush="#FFE6E9EE" BorderThickness="1"
                                            Effect="{StaticResource CardShadow}">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Abrir" Click="OpenFavorite_Click"/>
                                                <MenuItem Header="Mostrar en carpeta" Click="ShowInFolderFromItem_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Quitar de colección" Click="RemoveFromCollection_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid Width="280">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Thumbnail -->
                                            <Border Grid.Column="0" Width="72" Height="100" CornerRadius="6" Background="#FFF0F4F8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Width="72" Height="100"/>
                                            </Border>

                                            <!-- Meta -->
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="#FF0F1724" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Author}" FontSize="12" Foreground="#FF6B7280" Margin="0,2,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="8" Width="140" Background="#FFF1F5F9" Foreground="#FF3B82F6"/>
                                                    <TextBlock Text="{Binding RatingStars}" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Tags as chips -->
                                                <ItemsControl ItemsSource="{Binding Tags}" Margin="0,8,0,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource TagChip}">
                                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#FF374151"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <!-- Actions overlay (corner) -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0">
                                                <Button Style="{StaticResource ModernButtonStyle}" Background="#FF10B981" Foreground="White" Width="36" Height="30" Click="OpenFavorite_Click" ToolTip="Abrir cómic">
                                                    <TextBlock Text="📖" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource ModernButtonStyle}" Background="#FF60A5FA" Foreground="White" Width="36" Height="30" Click="ShowInFolderFromItem_Click" ToolTip="Mostrar en carpeta" Margin="6,0,0,0">
                                                    <TextBlock Text="📂" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource ModernButtonStyle}" Background="#FFEF4444" Foreground="White" Width="36" Height="30" Click="RemoveFromCollection_Click" ToolTip="Quitar de colección" Margin="6,0,0,0">
                                                    <TextBlock Text="🗑️" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </ScrollViewer>

                        <!-- Vista previa derecha -->
                        <Border Grid.Column="1" Background="#FFF8FAFC" CornerRadius="10" Padding="14" Margin="12,0,0,0">
                            <ContentControl Content="{Binding SelectedItem, ElementName=FavoritesListBox}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Border Height="220" Background="#FFF0F4F8" CornerRadius="8" HorizontalAlignment="Center">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Height="220"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Margin="0,12,0,0"/>
                                            <TextBlock Text="{Binding Author}" Foreground="#FF6B7280" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding DateAdded, StringFormat='Agregado: {0:dd/MM/yyyy}'}" Foreground="#FF9CA3AF" Margin="0,6,0,0"/>

                                            <TextBlock Text="Etiquetas" FontWeight="SemiBold" Margin="0,10,0,6"/>
                                            <ItemsControl ItemsSource="{Binding Tags}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource TagChip}">
                                                            <TextBlock Text="{Binding}" FontSize="12"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                                                <Button Style="{StaticResource ModernButtonStyle}" Background="#FF10B981" Foreground="White" Width="120" Click="OpenFavorite_Click">Abrir</Button>
                                                <Button Style="{StaticResource ModernButtonStyle}" Background="#FF60A5FA" Foreground="White" Width="120" Click="ShowInFolderFromItem_Click" Margin="8,0,0,0">Mostrar</Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#FFF3F4F6" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource ModernButtonStyle}"
                        Background="#FF8B5CF6" Foreground="White"
                        Click="ExportCollections_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="Exportar"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ModernButtonStyle}"
                        Background="#FF059669" Foreground="White"
                        Click="ImportCollections_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📥" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="Importar"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ModernButtonStyle}"
                        Background="#FF6B7280" Foreground="White"
                        Click="CloseWindow_Click">
                    <TextBlock Text="Cerrar"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
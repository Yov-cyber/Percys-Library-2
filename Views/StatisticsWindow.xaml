<Window x:Class="ComicReader.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Estadísticas"
        Height="680" Width="1100"
        MinHeight="520" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Surface.Base.Brush}"
        FontFamily="{DynamicResource AppFontFamily}"
        Foreground="{DynamicResource Text.Primary.Brush}">

    <!-- Diseno disciplinado: tipografia Segoe UI Variable, jerarquia clara
         (display / heading / body / caption), una columna principal de tarjetas
         y una columna lateral con sesiones del dia. Sin emojis decorativos en
         titulos, sin DropShadow, sin colores hardcoded. Todo via tokens. -->

    <Grid Margin="32,28,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============== HEADER ============== -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock DockPanel.Dock="Left" Text="Estadísticas"
                       FontSize="{DynamicResource FontSize.Display}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Text.Primary.Brush}"
                       VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Content="Cerrar"
                    Style="{DynamicResource Button.Secondary}"
                    Click="CloseButton_Click"
                    Padding="14,6" MinWidth="84"/>
        </DockPanel>

        <!-- ============== CONTENIDO PRINCIPAL ============== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- COLUMNA IZQUIERDA: KPIs + Progreso + Chart -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Margin="0,0,16,0">
                <StackPanel>

                    <!-- KPI cards: ItemsControl con WrapPanel -->
                    <ItemsControl ItemsSource="{Binding Stats}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="180" ItemHeight="92"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{DynamicResource Card}" Margin="0,0,12,12" Padding="16,12">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="{DynamicResource FontSize.Caption}"
                                                   Foreground="{DynamicResource Text.Secondary.Brush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Value}"
                                                   FontSize="{DynamicResource FontSize.Title}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text.Primary.Brush}"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Chart de actividad reciente -->
                    <Border Style="{DynamicResource Card}" Padding="20,16" Margin="0,4,0,16">
                        <StackPanel>
                            <TextBlock Text="Actividad reciente"
                                       FontSize="{DynamicResource FontSize.Title}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Text.Primary.Brush}"
                                       Margin="0,0,0,12"/>
                            <Grid Height="180">
                                <lvc:CartesianChart Series="{Binding Series}"
                                                    Background="Transparent"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Progreso actual: cómics en lectura -->
                    <Border Style="{DynamicResource Card}" Padding="20,16">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock DockPanel.Dock="Left" Text="En curso"
                                           FontSize="{DynamicResource FontSize.Title}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text.Primary.Brush}"/>
                                <TextBlock Text="{Binding ProgressList.Count, StringFormat='{}{0} cómics'}"
                                           DockPanel.Dock="Right"
                                           FontSize="{DynamicResource FontSize.Caption}"
                                           Foreground="{DynamicResource Text.Secondary.Brush}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- Lista limpia de progreso, sin marcos ni efectos -->
                            <ItemsControl ItemsSource="{Binding ProgressList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding Title}"
                                                       Foreground="{DynamicResource Text.Primary.Brush}"
                                                       FontSize="{DynamicResource FontSize.Body}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding PagesText}"
                                                       Foreground="{DynamicResource Text.Secondary.Brush}"
                                                       FontSize="{DynamicResource FontSize.Caption}"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"/>

                                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                                         Value="{Binding Percentage, Mode=OneWay}"
                                                         Minimum="0" Maximum="100"
                                                         Height="3" Margin="0,6,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Placeholder si no hay progreso -->
                            <TextBlock Text="Aún no hay cómics en curso"
                                       Foreground="{DynamicResource Text.Disabled.Brush}"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       Margin="0,12,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ProgressList.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- COLUMNA DERECHA: Preferencias + Sesiones de hoy -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Preferencias del lector -->
                <Border Grid.Row="0" Style="{DynamicResource Card}" Padding="20,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Tu lectura"
                                   FontSize="{DynamicResource FontSize.Title}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary.Brush}"
                                   Margin="0,0,0,12"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Género"
                                       Foreground="{DynamicResource Text.Secondary.Brush}"
                                       FontSize="{DynamicResource FontSize.Caption}"/>
                            <TextBlock Grid.Column="1" Text="{Binding FavoriteGenre}"
                                       Foreground="{DynamicResource Text.Primary.Brush}"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Día"
                                       Foreground="{DynamicResource Text.Secondary.Brush}"
                                       FontSize="{DynamicResource FontSize.Caption}"/>
                            <TextBlock Grid.Column="1" Text="{Binding FavoriteDay}"
                                       Foreground="{DynamicResource Text.Primary.Brush}"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Formato"
                                       Foreground="{DynamicResource Text.Secondary.Brush}"
                                       FontSize="{DynamicResource FontSize.Caption}"/>
                            <TextBlock Grid.Column="1" Text="{Binding PreferredFormat}"
                                       Foreground="{DynamicResource Text.Primary.Brush}"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Sesiones de hoy -->
                <Border Grid.Row="1" Style="{DynamicResource Card}" Padding="20,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Sesiones de hoy"
                                   FontSize="{DynamicResource FontSize.Title}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary.Brush}"
                                   Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding TodaySessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8" Margin="0,4"
                                                    Background="{DynamicResource Surface.Overlay.Brush}"
                                                    CornerRadius="6"
                                                    Focusable="True"
                                                    AutomationProperties.Name="{Binding Title}"
                                                    AutomationProperties.HelpText="{Binding HelpText}"
                                                    MouseLeftButtonDown="SessionItem_MouseLeftButtonDown"
                                                    KeyDown="SessionItem_KeyDown">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource Surface.Overlay.Brush}"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource Surface.Hover.Brush}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource Surface.Hover.Brush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="56"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding StartText}"
                                                               Foreground="{DynamicResource Text.Secondary.Brush}"
                                                               FontSize="{DynamicResource FontSize.Caption}"
                                                               VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{DynamicResource Text.Primary.Brush}"
                                                                   FontSize="{DynamicResource FontSize.Body}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding PagesText}"
                                                                   Foreground="{DynamicResource Text.Secondary.Brush}"
                                                                   FontSize="{DynamicResource FontSize.Caption}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding DurationText}"
                                                               Foreground="{DynamicResource Accent.Brush}"
                                                               FontSize="{DynamicResource FontSize.Body}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Margin="12,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Placeholder si no hay sesiones -->
                            <TextBlock Text="Aún no leíste hoy"
                                       Foreground="{DynamicResource Text.Disabled.Brush}"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TodaySessions.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ============== FOOTER ============== -->
        <DockPanel Grid.Row="2" Margin="0,20,0,0">
            <Button DockPanel.Dock="Right" Content="Resetear todo"
                    Style="{DynamicResource Button.Danger}"
                    Click="ResetButton_Click"
                    Padding="14,6" MinWidth="120"/>
            <Button DockPanel.Dock="Right" Content="Exportar CSV"
                    Style="{DynamicResource Button.Secondary}"
                    Click="ExportButton_Click"
                    Padding="14,6" MinWidth="120" Margin="0,0,8,0"/>
            <TextBlock/>
        </DockPanel>
    </Grid>
</Window>

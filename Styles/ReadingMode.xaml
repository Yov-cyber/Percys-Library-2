<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Reading-mode: styles and small animations. These use DynamicResource keys provided by ThemeManager
         so the visual appearance adapts automatically to the current theme. -->

    <!-- Entrance storyboard for the reader top bar: fade + slide up -->
    <Storyboard x:Key="ReaderTopBarEntrance">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.28"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="8" To="0" Duration="0:0:0.28"/>
    </Storyboard>

    <!-- Overlay fade in/out -->
    <Storyboard x:Key="ReaderOverlayFadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="0.96" Duration="0:0:0.22"/>
    </Storyboard>

    <Storyboard x:Key="ReaderOverlayFadeOut">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.96" To="0" Duration="0:0:0.22"/>
    </Storyboard>

    <!-- Animated ReaderTopBar style (overrides earlier ReaderTopBarStyle when merged last) -->
    <Style x:Key="ReaderTopBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="0"/>
            </Setter.Value>
        </Setter>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
                <!-- Entrance animation no longer auto-starts here. We start it from code-behind
                     so it can be disabled by user preferences (EnableAnimations). -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Overlay style used for reader overlay; uses theme overlay brush -->
    <Style x:Key="ReaderOverlayStyle" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource OverlayBackgroundBrush}"/>
        <Setter Property="Opacity" Value="0"/>
        <Style.Triggers>
            <!-- Overlay animation no longer auto-starts here; main window code will play it
                 if animations are enabled in settings. -->
        </Style.Triggers>
    </Style>

    <!-- Toggle button for reader (hover scale + subtle shadow) -->
    <!-- Simplified ToggleButton style to avoid complex control template errors during load. -->
    <!-- Keep the expected key name but target Button (MainWindow uses a Button control) -->
    <Style x:Key="ReaderToggleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- Give buttons a smooth press/hover transition via implicit animation resources -->
    <Style TargetType="Button" x:Key="ReadingSmallButton">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- Only apply hover scale when both IsMouseOver and the per-area animations flag are true -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    <!-- Bind to the App resources dictionary at runtime to avoid StaticResource ordering issues -->
                    <Condition Binding="{Binding Source={x:Static Application.Current}, Path=Resources[AppSettingsProxy].EnableAnimationsButtons}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.04" ScaleY="1.04"/>
                    </Setter.Value>
                </Setter>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Small icon button used in the reader top bar; theme-aware and compact -->
    <!-- ReadingSmallButton is defined above in this same ResourceDictionary, so use StaticResource
        for BasedOn (DynamicResource is not valid for Style.BasedOn and causes XAML parse errors). -->
    <Style x:Key="ReaderIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ReadingSmallButton}">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"
                            RenderTransform="{TemplateBinding RenderTransform}" RenderTransformOrigin="0.5,0.5">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.10"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- Hover/press visual tweaks -->
            <Trigger Property="IsPressed" Value="True">
                <!-- Pressed: slight translate to mimic depth -->
                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="1" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            <!-- If animations for buttons are enabled, apply a subtle scale on hover -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    <Condition Binding="{Binding Source={x:Static Application.Current}, Path=Resources[AppSettingsProxy].EnableAnimationsButtons}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource AccentLowBrush}" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.06" ScaleY="1.06" />
                    </Setter.Value>
                </Setter>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

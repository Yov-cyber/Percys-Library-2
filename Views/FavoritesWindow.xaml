<Window x:Class="ComicReader.Views.FavoritesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
        xmlns:controls="clr-namespace:ComicReader.Controls"
        Title="Colecciones"
        Width="1280" Height="820"
        MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Surface.Base.Brush}"
        FontFamily="{DynamicResource AppFontFamily}"
        Foreground="{DynamicResource Text.Primary.Brush}">

    <!-- Layout estilo Cover (https://cover.cool):
         Sidebar permanente con la lista de colecciones a la izquierda,
         panel central con la grilla de portadas y barra de filtros arriba.
         Todo via Tokens; nada de chrome decorativo. -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- =================================================
             SIDEBAR INTERNO (izquierda): lista de colecciones
             ================================================= -->
        <Border Grid.Column="0"
                Background="{DynamicResource Surface.Raised.Brush}"
                BorderBrush="{DynamicResource Border.Subtle.Brush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Encabezado del sidebar -->
                <StackPanel Grid.Row="0" Margin="20,24,20,12">
                    <TextBlock Text="Colecciones"
                               FontSize="{DynamicResource FontSize.Display}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Text.Primary.Brush}"/>
                    <TextBlock x:Name="StatusText"
                               Text=""
                               FontSize="{DynamicResource FontSize.Caption}"
                               Foreground="{DynamicResource Text.Secondary.Brush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Lista de colecciones: filas limpias, una linea por coleccion,
                     con contador discreto a la derecha. Estado activo via
                     ListBoxItem.IsSelected (estilo del sistema). -->
                <ListBox Grid.Row="1" x:Name="CollectionsListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="CollectionsListBox_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Padding="8,4">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background"
                                                        Value="{DynamicResource Surface.Hover.Brush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background"
                                                        Value="{DynamicResource Surface.Selected.Brush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="{DynamicResource FontSize.Body}"
                                           Foreground="{DynamicResource Text.Primary.Brush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ItemCount}"
                                           FontSize="{DynamicResource FontSize.Caption}"
                                           Foreground="{DynamicResource Text.Secondary.Brush}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Footer del sidebar: crear / importar / exportar -->
                <StackPanel Grid.Row="2" Margin="16,8,16,16">
                    <Button Content="+ Nueva colección"
                            Style="{DynamicResource Button.Primary}"
                            Click="CreateCollection_Click"
                            Padding="12,8" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Importar"
                                Style="{DynamicResource Button.Secondary}"
                                Click="ImportCollections_Click"
                                Padding="8,6" Margin="0,0,4,0"/>
                        <Button Grid.Column="1" Content="Exportar"
                                Style="{DynamicResource Button.Secondary}"
                                Click="ExportCollections_Click"
                                Padding="8,6" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =================================================
             PANEL CENTRAL: titulo + filtros + grilla de portadas
             ================================================= -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: titulo de la coleccion + cerrar -->
            <DockPanel Grid.Row="0" Margin="32,28,32,16">
                <Button DockPanel.Dock="Right" Content="Cerrar"
                        Style="{DynamicResource Button.Secondary}"
                        Click="CloseWindow_Click"
                        Padding="14,6" MinWidth="84"/>
                <TextBlock x:Name="CollectionTitleText"
                           Text="Selecciona una colección"
                           FontSize="{DynamicResource FontSize.Display}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Text.Primary.Brush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>

            <!-- Sub-header: estadisticas de la coleccion + busqueda + filtros + acciones -->
            <Grid Grid.Row="1" Margin="32,0,32,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Estadisticas de la coleccion seleccionada -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total:"
                               FontSize="{DynamicResource FontSize.Caption}"
                               Foreground="{DynamicResource Text.Secondary.Brush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TotalComicsText" Text="0"
                               FontSize="{DynamicResource FontSize.Body}"
                               Foreground="{DynamicResource Text.Primary.Brush}"
                               FontWeight="SemiBold" Margin="6,0,16,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="En curso:"
                               FontSize="{DynamicResource FontSize.Caption}"
                               Foreground="{DynamicResource Text.Secondary.Brush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ReadingComicsText" Text="0"
                               FontSize="{DynamicResource FontSize.Body}"
                               Foreground="{DynamicResource Text.Primary.Brush}"
                               FontWeight="SemiBold" Margin="6,0,16,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Completados:"
                               FontSize="{DynamicResource FontSize.Caption}"
                               Foreground="{DynamicResource Text.Secondary.Brush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="CompletedComicsText" Text="0"
                               FontSize="{DynamicResource FontSize.Body}"
                               Foreground="{DynamicResource Text.Primary.Brush}"
                               FontWeight="SemiBold" Margin="6,0,16,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Rating:"
                               FontSize="{DynamicResource FontSize.Caption}"
                               Foreground="{DynamicResource Text.Secondary.Brush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="AverageRatingText" Text="0"
                               FontSize="{DynamicResource FontSize.Body}"
                               Foreground="{DynamicResource Text.Primary.Brush}"
                               FontWeight="SemiBold" Margin="6,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Acciones / busqueda -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="SearchTextBox"
                             Width="240"
                             TextChanged="SearchTextBox_TextChanged"
                             Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             Padding="10,6"
                             ToolTip="Buscar en la colección"/>
                    <ComboBox x:Name="TagFilterComboBox"
                              Width="140"
                              SelectionChanged="TagFilterComboBox_SelectionChanged"
                              Margin="0,0,8,0"
                              ToolTip="Filtrar por etiqueta">
                        <!-- Sin IsSelected="True": dispararia SelectionChanged durante
                             InitializeComponent cuando FilteredItems aun es null,
                             produciendo NRE y abortando la carga del BAML. La seleccion
                             inicial se aplica programaticamente desde
                             CollectionsListBox_SelectionChanged -> combo.SelectedIndex = 0. -->
                        <ComboBoxItem Content="(Todos)"/>
                    </ComboBox>
                    <Button Content="Añadir carpeta"
                            Style="{DynamicResource Button.Secondary}"
                            Click="AddFolderToCollection_Click"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>

            <!-- Grilla de portadas. ListBox con WrapPanel virtualizado para que escale
                 a colecciones grandes. Drag-to-reorder via GongSolutions. Drop de
                 archivos del explorador via FavoritesListBox_Drop. -->
            <ListBox Grid.Row="2" x:Name="FavoritesListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     SelectionMode="Extended"
                     Padding="24,0,24,16"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     AllowDrop="True"
                     dd:DragDrop.IsDragSource="True"
                     dd:DragDrop.IsDropTarget="True"
                     dd:DragDrop.UseDefaultDragAdorner="True">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- VirtualizingWrapPanel del repo: extiende VirtualizingPanel + IScrollInfo,
                             asi VirtualizingPanel.IsVirtualizing y ScrollViewer.CanContentScroll
                             surten efecto. ItemWidth/Height incluyen Margin (160+12, 220+44+16+10). -->
                        <controls:VirtualizingWrapPanel ItemWidth="172" ItemHeight="290"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <EventSetter Event="MouseDoubleClick" Handler="OpenFavorite_Click"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Padding="0">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource Surface.Selected.Brush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="160" Margin="6,8" Background="Transparent">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Abrir" Click="OpenFavorite_Click"/>
                                    <MenuItem Header="Mostrar en carpeta" Click="ShowInFolderFromItem_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Quitar de la colección" Click="RemoveFromCollection_Click"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="220"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Cover con progreso integrado al pie -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource Surface.Overlay.Brush}"
                                    BorderBrush="{DynamicResource Border.Subtle.Brush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    ClipToBounds="True"
                                    SnapsToDevicePixels="True"
                                    UseLayoutRounding="True">
                                <Grid>
                                    <Image Source="{Binding ThumbnailImage}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                                                 Minimum="0" Maximum="100"
                                                 Height="3"
                                                 VerticalAlignment="Bottom"
                                                 Background="Transparent"
                                                 BorderThickness="0"/>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding Title}"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       Foreground="{DynamicResource Text.Primary.Brush}"
                                       FontWeight="SemiBold"
                                       Margin="2,8,2,0"
                                       MaxHeight="40"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="2"
                                       Text="{Binding Author}"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       Foreground="{DynamicResource Text.Secondary.Brush}"
                                       Margin="2,2,2,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Footer: acciones sobre seleccion -->
            <DockPanel Grid.Row="3" Margin="32,12,32,20">
                <Button DockPanel.Dock="Right" Content="Eliminar colección"
                        Style="{DynamicResource Button.Danger}"
                        Click="DeleteCollection_Click"
                        Padding="14,6" Margin="8,0,0,0"/>
                <Button DockPanel.Dock="Right" Content="Duplicar"
                        Style="{DynamicResource Button.Secondary}"
                        Click="DuplicateCollection_Click"
                        Padding="14,6" Margin="8,0,0,0"/>
                <Button DockPanel.Dock="Right" Content="Renombrar"
                        Style="{DynamicResource Button.Secondary}"
                        Click="RenameCollection_Click"
                        Padding="14,6" Margin="8,0,0,0"/>
                <Button DockPanel.Dock="Right" Content="Quitar selección"
                        Style="{DynamicResource Button.Secondary}"
                        Click="RemoveSelected_Click"
                        Padding="14,6"/>
                <TextBlock/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>

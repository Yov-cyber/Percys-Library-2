<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ComicReader.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ComicReader.ViewModels"
        Title="Configuración - Percy's Library"
        Height="820" Width="1200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <!-- Fonts -->
        <FontFamily x:Key="ComicTitleFont">Bangers, "Komika Axis", "Comic Sans MS", Segoe UI</FontFamily>
        <FontFamily x:Key="UiFont">Segoe UI, Roboto, Arial</FontFamily>

        <!-- Styles: hybrid comic classic + modern con tema dinámico -->
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#66000000" BlurRadius="10" ShadowDepth="4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Comic button (primary look) con tema dinámico -->
        <Style x:Key="ComicButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource ComicTitleFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Margin" Value="6,4,6,4"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border IsHitTestVisible="False" CornerRadius="8" BorderBrush="Black" BorderThickness="2" Margin="-3"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="1.04" ScaleY="1.04"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value><TranslateTransform Y="1"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryAction" TargetType="Button" BasedOn="{StaticResource ComicButton}">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <Style x:Key="SecondaryAction" TargetType="Button" BasedOn="{StaticResource ComicButton}">
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource ComicTitleFont}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox style con tema dinámico -->
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>

        <!-- CheckBox style con tema dinámico -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- TextBox style con tema dinámico -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Slider style con tema dinámico -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- ViewModel instance -->
        <vm:SettingsViewModel x:Key="SettingsVM" />
    </Window.Resources>

    <Grid DataContext="{StaticResource SettingsVM}">
        <Border Style="{StaticResource PanelCard}" Margin="12">
            <DockPanel LastChildFill="True">

                <!-- Header -->
                <DockPanel DockPanel.Dock="Top" Margin="4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6">
                        <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8" Padding="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="3">
                            <TextBlock Text="PERCY'S LIBRARY" Foreground="{DynamicResource TextBrush}" FontFamily="{StaticResource ComicTitleFont}" FontSize="20" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="  Configuración" Style="{StaticResource SectionHeader}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Style="{StaticResource ComicButton}" Content="Exportar" Click="Export_Click" MinWidth="100"/>
                        <Button Style="{StaticResource ComicButton}" Content="Importar" Click="Import_Click" MinWidth="100"/>
                        <Button Style="{StaticResource PrimaryAction}" Content="Aplicar" Click="Apply_Click" MinWidth="100"/>
                        <Button Style="{StaticResource SecondaryAction}" Content="Cancelar" Click="Close_Click" MinWidth="100"/>
                    </StackPanel>
                </DockPanel>

                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar (categories) -->
                    <StackPanel Grid.Column="0" Margin="4">
                        <TextBox x:Name="SearchBox" Height="36" FontFamily="{StaticResource UiFont}" FontSize="14"
                                 VerticalContentAlignment="Center" Margin="0,0,0,8" TextChanged="SearchBox_TextChanged" />

                        <StackPanel>
                            <!-- Each button sets SelectedSection via command -->
                            <Button Style="{StaticResource ComicButton}" Content="⚙️  General" Command="{Binding SelectSectionCommand}" CommandParameter="General"/>
                            <Button Style="{StaticResource ComicButton}" Content="🎨  Apariencia" Command="{Binding SelectSectionCommand}" CommandParameter="Apariencia" />
                            <Button Style="{StaticResource ComicButton}" Content="📖  Lectura" Command="{Binding SelectSectionCommand}" CommandParameter="Lectura" />
                            <Button Style="{StaticResource ComicButton}" Content="🎮  Controles" Command="{Binding SelectSectionCommand}" CommandParameter="Controles" />
                            <Button Style="{StaticResource ComicButton}" Content="⚡  Rendimiento" Command="{Binding SelectSectionCommand}" CommandParameter="Rendimiento" />
                            <Button Style="{StaticResource ComicButton}" Content="🔒  Seguridad" Command="{Binding SelectSectionCommand}" CommandParameter="Seguridad" />
                            <Button Style="{StaticResource ComicButton}" Content="🧩  Personalización avanzada" Command="{Binding SelectSectionCommand}" CommandParameter="Personalizacion" />
                            <Button Style="{StaticResource ComicButton}" Content="💬  Acerca de" Command="{Binding SelectSectionCommand}" CommandParameter="Acerca" />
                        </StackPanel>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="3" CornerRadius="8" Margin="0,12,0,0" Padding="10" Background="{DynamicResource PanelBackgroundBrush}">
                            <StackPanel>
                                <TextBlock Text="Atajos" FontFamily="{StaticResource ComicTitleFont}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox IsChecked="{Binding AppSettings.AutoSaveEnabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Auto-guardar" Margin="8,0,0,0" FontFamily="{StaticResource UiFont}" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                <Button Style="{StaticResource ComicButton}" Content="Abrir carpeta de instalación" Command="{Binding OpenFolderCommand}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Separator -->
                    <Rectangle Grid.Column="1" Fill="#222222" Width="2" Margin="0,6"/>

                    <!-- Main content (right) -->
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="12">
                        <StackPanel>

                            <!-- GENERAL -->
                            <StackPanel x:Name="Panel_General" Margin="0,4,0,8">
                                <TextBlock Text="GENERAL" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="3" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Recordar última sesión" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.RememberLastSession, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Abrir último cómic al iniciar" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.OpenLastOnStartup, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Mostrar miniaturas" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.ThumbnailsVisible, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,10">
                                            <TextBlock Text="Carpeta por defecto" Style="{StaticResource LabelText}" Width="360"/>
                                            <TextBlock Text="{Binding AppSettings.DefaultComicsFolder}" Style="{StaticResource LabelText}" Width="280" TextTrimming="CharacterEllipsis"/>
                                            <Button Style="{StaticResource ComicButton}" Content="Cambiar" Command="{Binding ChangeFolderCommand}" Margin="4,0" MinWidth="90" Padding="12,8"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource ComicButton}" Content="Restaurar por defecto" Command="{Binding RestoreDefaultsCommand}" Padding="14,8" MinWidth="180"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- APARIENCIA -->
                            <StackPanel x:Name="Panel_Apariencia" Margin="0,4,0,8" Visibility="Collapsed">
                                <TextBlock Text="APARIENCIA" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="3" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Tema global" Style="{StaticResource LabelText}" Width="360"/>
                                            <ComboBox x:Name="ThemeCombo" ItemsSource="{Binding ThemeInfos}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedThemeInfo, Mode=TwoWay}" Width="380" SelectionChanged="ThemeCombo_SelectionChanged"/>
                                        </StackPanel>

                                        <!-- 'Tema de la pantalla principal' eliminado: la selección por pantalla ya no está disponible -->

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Color de acento" Style="{StaticResource LabelText}" Width="360"/>
                                            <ComboBox ItemsSource="{Binding AccentColors}" SelectedItem="{Binding AppSettings.AccentColorName, Mode=TwoWay}" Width="380"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Fuente de lectura" Style="{StaticResource LabelText}" Width="360"/>
                                            <ComboBox ItemsSource="{Binding AvailableFonts}" SelectedItem="{Binding AppSettings.ReaderFontName, Mode=TwoWay}" Width="380"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Tamaño UI" Style="{StaticResource LabelText}" Width="360"/>
                                            <ComboBox x:Name="UIScaleCombo" Width="380" SelectionChanged="UIScaleCombo_SelectionChanged">
                                                <ComboBoxItem Content="Pequeño" Tag="Small"/>
                                                <ComboBoxItem Content="Mediano" Tag="Medium"/>
                                                <ComboBoxItem Content="Grande" Tag="Large"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <TextBlock Text="💡 Los cambios de tema se previsualizan al instante. Haz clic en 'Aplicar' para guardarlos permanentemente." 
                                                   Style="{StaticResource LabelText}" 
                                                   FontSize="12"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Margin="0,12,0,0"/>

                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- LECTURA -->
                            <StackPanel x:Name="Panel_Lectura" Margin="0,4,0,8" Visibility="Collapsed">
                                <TextBlock Text="LECTURA" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="3" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Dirección de lectura" Style="{StaticResource LabelText}" Width="360"/>
                                            <ComboBox x:Name="ReadingDirectionCombo" Width="200" SelectionChanged="ReadingDirectionCombo_SelectionChanged">
                                                <ComboBoxItem Content="Izquierda a Derecha" Tag="LeftToRight"/>
                                                <ComboBoxItem Content="Derecha a Izquierda" Tag="RightToLeft"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Tipo de lectura" Style="{StaticResource LabelText}" Width="360"/>
                                            <ComboBox x:Name="ReadingModeCombo" Width="200" SelectionChanged="ReadingModeCombo_SelectionChanged">
                                                <ComboBoxItem Content="Página por página" Tag="PageByPage"/>
                                                <ComboBoxItem Content="Continuo" Tag="Continuous"/>
                                                <ComboBoxItem Content="Doble página" Tag="DoublePage"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Animación al pasar página" Style="{StaticResource LabelText}" Width="360"/>
                                            <ComboBox x:Name="PageTurnAnimationCombo" Width="200" SelectionChanged="PageTurnAnimationCombo_SelectionChanged">
                                                <ComboBoxItem Content="Ninguna" Tag="None"/>
                                                <ComboBoxItem Content="Fundido" Tag="Fade"/>
                                                <ComboBoxItem Content="Deslizar" Tag="Slide"/>
                                                <ComboBoxItem Content="Voltear" Tag="Flip"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Zoom por defecto (%)" Style="{StaticResource LabelText}" Width="360"/>
                                            <Slider Minimum="50" Maximum="200" Value="{Binding AppSettings.DefaultZoomPercent, Mode=TwoWay}" Width="260"/>
                                            <TextBlock Text="{Binding AppSettings.DefaultZoomPercent}" Width="40" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Mostrar número de página" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.ShowPageNumbers, Mode=TwoWay}"/>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- CONTROLES -->
                            <StackPanel x:Name="Panel_Controles" Margin="0,4,0,8" Visibility="Collapsed">
                                <TextBlock Text="CONTROLES" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="3" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Navegación táctil" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.TouchNavigation, Mode=TwoWay}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Atajos de teclado" Style="{StaticResource LabelText}" Width="360"/>
                                            <Button Style="{StaticResource ComicButton}" Content="Editar atajos" Command="{Binding ConfigureShortcutsCommand}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Sensibilidad del scroll" Style="{StaticResource LabelText}" Width="360"/>
                                            <Slider Minimum="0.2" Maximum="2.0" Value="{Binding AppSettings.ScrollSensitivity, Mode=TwoWay}" Width="260"/>
                                            <TextBlock Text="{Binding AppSettings.ScrollSensitivity, StringFormat={}{0:F2}}" Width="50" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- RENDIMIENTO -->
                            <StackPanel x:Name="Panel_Rendimiento" Margin="0,4,0,8" Visibility="Collapsed">
                                <TextBlock Text="RENDIMIENTO" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="3" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Precarga de páginas" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.EnableEagerPreload, Mode=TwoWay}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Tamaño máximo de caché (MB)" Style="{StaticResource LabelText}" Width="360"/>
                                            <TextBox Text="{Binding AppSettings.EagerPreloadDiskMaxMB, Mode=TwoWay}" Width="160"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,12">
                                            <Button Style="{StaticResource ComicButton}" Content="Limpiar caché" Command="{Binding ClearCacheCommand}" />
                                            <Button Style="{StaticResource ComicButton}" Content="Optimizar ahora" Command="{Binding OptimizeCommand}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- SEGURIDAD -->
                            <StackPanel x:Name="Panel_Seguridad" Margin="0,4,0,8" Visibility="Collapsed">
                                <TextBlock Text="SEGURIDAD" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="3" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Bloqueo con PIN" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.PINLockEnabled, Mode=TwoWay}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Ocultar cómics privados" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.HidePrivateComics, Mode=TwoWay}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,12">
                                            <Button Style="{StaticResource ComicButton}" Content="Exportar ajustes" Command="{Binding ExportCommandWithDialog}" />
                                            <Button Style="{StaticResource ComicButton}" Content="Importar ajustes" Command="{Binding ImportCommandWithDialog}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- PERSONALIZACIÓN AVANZADA -->
                            <StackPanel x:Name="Panel_Personalizacion" Margin="0,4,0,8" Visibility="Collapsed">
                                <TextBlock Text="PERSONALIZACIÓN AVANZADA" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="3" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Activar efectos pop-art (POW!)" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.EnableComicEffects, Mode=TwoWay}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Habilitar animaciones en la interfaz" Style="{StaticResource LabelText}" Width="360"/>
                                            <CheckBox IsChecked="{Binding AppSettings.AnimationsEnabled, Mode=TwoWay}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6">
                                            <TextBlock Text="Borde de viñeta: grosor" Style="{StaticResource LabelText}" Width="360"/>
                                            <Slider Minimum="1" Maximum="14" Value="{Binding AppSettings.VignetteBorderThickness, Mode=TwoWay}" Width="260"/>
                                            <TextBlock Text="{Binding AppSettings.VignetteBorderThickness}" Width="40" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,12">
                                            <Button Style="{StaticResource ComicButton}" Content="Restablecer apariencia avanzada" Command="{Binding ResetAdvancedAppearanceCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ACERCA -->
                            <StackPanel x:Name="Panel_Acerca" Margin="0,4,0,8" Visibility="Collapsed">
                                <TextBlock Text="ACERCA DE" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="3" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Percy's Library" FontFamily="{StaticResource ComicTitleFont}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="Versión 1.0.0" Margin="0,6,0,0" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="Creado por Geovany Yunior Peguero Rosario. Gracias por usar la app." TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{DynamicResource TextBrush}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Style="{StaticResource ComicButton}" Content="Ver créditos" Command="{Binding ViewCreditsCommand}"/>
                                            <Button Style="{StaticResource ComicButton}" Content="Sitio web" Command="{Binding OpenWebsiteCommand}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>



                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
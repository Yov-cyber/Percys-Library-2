<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ComicReader.Views.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logros — Percy's Library"
        Height="640" Width="880"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Surface.Base.Brush}"
        FontFamily="{DynamicResource AppFontFamily}">

    <Window.Resources>
        <!-- Card de logro: estilos discretos, sin glow ni scale-on-hover.
             Cuando el logro esta locked, baja la opacidad para indicarlo. -->
        <Style x:Key="AchievementCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Width" Value="260"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Unlocked}" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AchievementGlyph" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary.Brush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <!-- Cuando esta locked, lo oscurecemos opacando todo el card desde el code-behind. -->
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="32,24,32,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Logros"
                           Style="{DynamicResource Text.Title}"
                           FontSize="{DynamicResource FontSize.Display}"/>
                <TextBlock x:Name="HeaderSubtitle"
                           Foreground="{DynamicResource Text.Secondary.Brush}"
                           FontSize="{DynamicResource FontSize.Body}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Cerrar"
                    Style="{DynamicResource Button.Secondary}"
                    Click="Close_Click"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- BARRA DE PROGRESO GLOBAL -->
        <Grid Grid.Row="1" Margin="32,0,32,16">
            <ProgressBar x:Name="OverallProgress" Height="3" Minimum="0" Maximum="100"/>
        </Grid>

        <!-- CATALOGO -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="26,0,26,16">
            <ItemsControl x:Name="AchievementsList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource AchievementCard}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="44" Height="44"
                                            CornerRadius="22"
                                            Background="{DynamicResource Surface.Overlay.Brush}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding IconGlyph}" Style="{StaticResource AchievementGlyph}"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource Text.Primary.Brush}"
                                                   FontSize="{DynamicResource FontSize.Body}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{DynamicResource Text.Secondary.Brush}"
                                                   FontSize="{DynamicResource FontSize.Caption}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Progreso -->
                                <ProgressBar Height="3"
                                             Minimum="0" Maximum="1"
                                             Value="{Binding Progress, Mode=OneWay}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ProgressLabel}"
                                               Foreground="{DynamicResource Text.Secondary.Brush}"
                                               FontSize="{DynamicResource FontSize.Caption}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding UnlockedAt, StringFormat='Desbloqueado {0:dd MMM yyyy}'}"
                                               Foreground="{DynamicResource Accent.Brush}"
                                               FontSize="{DynamicResource FontSize.Caption}"
                                               Visibility="{Binding Unlocked, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>

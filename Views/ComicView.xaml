<UserControl x:Class="ComicReader.Views.ComicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="400" Width="600">
    
    <UserControl.Resources>
        <Style x:Key="ComicPageStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Surface.Base.Brush}">
        
        <ScrollViewer x:Name="ComicScrollViewer" 
                      Margin="0,35,0,50" 
                      HorizontalScrollBarVisibility="Auto" 
                      VerticalScrollBarVisibility="Auto"
                      Background="Transparent">
            
            <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                  MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                
                <Border x:Name="ComicPageBorder"
                        Style="{StaticResource ComicPageStyle}"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        MaxWidth="800" MaxHeight="1200">
                    
                    <Image x:Name="imageViewer"
                           Stretch="Uniform"
                           StretchDirection="Both"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    
                </Border>
            </Grid>
        </ScrollViewer>

        <Grid x:Name="LoadingPanel" Background="#80000000" Visibility="Collapsed">
            <Border Background="{DynamicResource Surface.Overlay.Brush}" CornerRadius="6" Padding="24,16" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Cargando…" FontSize="14" Foreground="{DynamicResource Text.Primary.Brush}" HorizontalAlignment="Center"/>
            </Border>
        </Grid>

    </Grid>
</UserControl>

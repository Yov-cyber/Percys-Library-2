<UserControl x:Class="ComicReader.Views.Sections.ReadingSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">
  <Border Style="{StaticResource SettingsCard}">
    <StackPanel>
      <TextBlock Text="Lectura" FontWeight="Bold" FontSize="16" />
      <StackPanel Margin="0,8,0,0">
        <TextBlock Text="Dirección de lectura" />
        <ComboBox SelectedItem="{Binding AppSettings.ReadingDirection, Mode=TwoWay}" Width="200" />
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>

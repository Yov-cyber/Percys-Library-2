<Window x:Class="ComicReader.Views.PreloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Precargando" Height="140" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Precargando páginas..." FontWeight="SemiBold" FontSize="14"/>
    <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="18" Margin="0,8,0,0" Minimum="0" Maximum="100" Style="{StaticResource ModernProgressBarStyle}">
            <ProgressBar.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </ProgressBar.Triggers>
        </ProgressBar>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0" HorizontalAlignment="Stretch">
            <TextBlock x:Name="ProgressText" FontSize="12" Foreground="Gray" Text="0 / 0" HorizontalAlignment="Left"/>
            <TextBlock x:Name="ProgressPct" FontSize="12" Foreground="Gray" Text="0%" HorizontalAlignment="Center" Margin="12,0,0,0"/>
            <TextBlock x:Name="EtaText" FontSize="12" Foreground="Gray" Text="" HorizontalAlignment="Right" Margin="12,0,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelButton" Content="Cancelar" Width="90" Margin="0,0,8,0" Click="CancelButton_Click" Style="{StaticResource ModernDialogButtonStyle}"/>
            <Button x:Name="CloseButton" Content="Cerrar" Width="90" Click="CloseButton_Click" IsEnabled="False" Style="{StaticResource ModernDialogButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>

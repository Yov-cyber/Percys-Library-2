<UserControl x:Class="ComicReader.Views.EnhancedContinuousComicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ComicReader.Views"
             xmlns:conv="clr-namespace:ComicReader.Converters"
             Background="{DynamicResource BackgroundBrush}">
    
    <!-- Recursos y Estilos -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        
        <!-- Estilo de botón moderno -->
        <Style x:Key="ModernIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#555"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#222"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <!-- ScrollViewer principal con zoom -->
        <ScrollViewer x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly"
                      Background="Transparent">
            
            <!-- Contenedor de páginas -->
            <ItemsControl x:Name="PagesContainer"
                          ItemsSource="{Binding Pages, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          HorizontalAlignment="Center">
                
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- StackPanel vertical para disposición continua -->
                        <VirtualizingStackPanel Orientation="Vertical"
                                               VirtualizingPanel.IsVirtualizing="True"
                                               VirtualizingPanel.VirtualizationMode="Recycling"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Contenedor de cada página -->
                        <Border Margin="0,5"
                                Background="Transparent"
                                HorizontalAlignment="Center">
                            
                            <Grid>
                                <!-- Placeholder mientras carga -->
                                <Border x:Name="PlaceholderBorder"
                                        Background="#F5F5F5"
                                        MinHeight="800"
                                        MinWidth="600"
                                        CornerRadius="4"
                                        Visibility="{Binding IsLoaded, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <StackPanel VerticalAlignment="Center"
                                               HorizontalAlignment="Center">
                                        <ProgressBar IsIndeterminate="True"
                                                   Width="100"
                                                   Height="4"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding PageNumber, StringFormat='Cargando página {0}...'}"
                                                 Foreground="#999"
                                                 FontSize="14"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Imagen de la página -->
                                <Image Source="{Binding Image}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased"
                                       Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibilityConverter}}">
                                    
                                    <!-- Animación de fade in cuando carga -->
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="Visibility" Value="Visible">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                               From="0" To="1"
                                                                               Duration="0:0:0.3"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Panel de controles de zoom (overlay) -->
        <Border x:Name="ZoomControlsPanel"
                Background="#CC000000"
                CornerRadius="20"
                Padding="12,8"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="20">
            
            <StackPanel Orientation="Horizontal">
                <!-- Zoom Out -->
                <Button Content="−"
                        Margin="4,0"
                        Width="36"
                        Height="36"
                        FontSize="20"
                        Click="ZoomOutButton_Click"
                        Style="{StaticResource ModernIconButtonStyle}"
                        ToolTip="Alejar (Ctrl + -)"/>
                
                <!-- Zoom Level -->
                <TextBlock x:Name="ZoomLabel"
                           Text="100%"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           MinWidth="50"
                           TextAlignment="Center"
                           Margin="8,0"/>
                
                <!-- Zoom In -->
                <Button Content="+"
                        Width="36"
                        Height="36"
                        FontSize="20"
                        Click="ZoomInButton_Click"
                        Style="{StaticResource ModernIconButtonStyle}"
                        ToolTip="Acercar (Ctrl + +)"
                        Margin="4,0"/>
                
                <!-- Reset Zoom -->
                <Button Content="⟲"
                        Width="36"
                        Height="36"
                        FontSize="18"
                        Click="ResetZoomButton_Click"
                        Style="{StaticResource ModernIconButtonStyle}"
                        ToolTip="Restablecer zoom (Ctrl + 0)"
                        Margin="4,0"/>
            </StackPanel>
        </Border>

        <!-- Indicador de carga inicial -->
        <Grid x:Name="LoadingPanel"
              Background="#F0FFFFFF"
              Visibility="Collapsed">
            
            <StackPanel VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                           Width="200"
                           Height="6"
                           Margin="0,0,0,20"/>
                <TextBlock Text="Preparando cómic..."
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#333"/>
                <TextBlock Text="Un momento mientras cargamos las páginas"
                         FontSize="14"
                         Foreground="#666"
                         Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
